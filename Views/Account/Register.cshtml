@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Account.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
</head>
<body>

<a href="/Home/Index" class="back-link">
    <i class="fas fa-angle-left"></i>
</a>

<div class="container">
    <div class="hero-section">
            <p class="tagline">IT'S TIME TO</p>
            <div id="dynamic-logo" class="run-logo"></div>
    </div>

    <div class="form-section">
        <div class="register-card">
            <h2 class="card">Register</h2>
            <div id="errorMessage" role="alert" class="error d-none"></div>
            <form id="registerForm">
                <label>Email</label>
                <div class="input-group">
                    <i class="fa-solid fa-envelope"></i>
                    <input type="email" id="email" placeholder="your@email.com" required />
                </div>

                <label>Username</label>
                <div class="input-group">
                    <i class="fa-solid fa-user"></i>
                    <input type="text" id="username" placeholder="Enter your username" required />
                </div>
                <label>Password</label>
                <div class="input-group">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" id="password" placeholder="Enter your password" required />
                </div>
                <label>Confirm Password</label>
                <div class="input-group">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" id="confirmPassword" placeholder="Confirm your password" required />
                </div>

                <button type="submit" id="btnSubmit" class="register-btn">
                    <span class="loading-spinner"></span>
                    REGISTER
                </button>
            </form>
            <p class="login-text">Already have an account? <a href="/Account/Login">Login here!</a></p>
        </div>
    </div>
</div>

<script>
    const words = ["RUN", "CYCLE", "BASKETBALL", "SOCCER", "VOLLEYBALL"];
    let wordIndex = 0;
    const logoContainer = document.getElementById('dynamic-logo');
    const registerForm = document.getElementById("registerForm");
    const errorDiv = document.getElementById("errorMessage");
    const btnSubmit = document.getElementById("btnSubmit");

    function setLoading(isLoading) {
        if (!btnSubmit) return;
        btnSubmit.disabled = isLoading;
        btnSubmit.classList.toggle('loading', isLoading);
    }

    registerForm?.addEventListener("submit", async function (e) {
        e.preventDefault();

        const email = document.getElementById("email").value.trim();
        const username = document.getElementById("username").value.trim();
        const password = document.getElementById("password").value;
        const confirmPassword = document.getElementById("confirmPassword").value;

        if (password !== confirmPassword) {
            errorDiv.innerText = "Passwords do not match!";
            errorDiv.classList.remove("d-none");
            document.getElementById("confirmPassword").focus();
            return;
        }

        if (password.length < 6) {
            errorDiv.innerText = "Password must be at least 6 characters long.";
            errorDiv.classList.remove("d-none");
            return;
        }

        errorDiv.classList.add("d-none");
        setLoading(true);

        try {
            const res = await fetch("/api/auth/register", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ Email: email, Username: username, Password: password })
            });

            if (res.ok) {
                window.location.href = "/Account/Login";
                return;
            }

            const errorData = await res.json();
            errorDiv.innerText = errorData.message || "Registration failed.";
            errorDiv.classList.remove("d-none");
            document.getElementById("email").focus();
        } catch (err) {
            errorDiv.innerText = "Network error: " + err.message;
            errorDiv.classList.remove("d-none");
        } finally {
            setLoading(false);
        }
    });

    async function smoothChangeWord() {
        if (!logoContainer) return;

        const currentCols = logoContainer.querySelectorAll('.column');
        currentCols.forEach(col => {
            col.style.opacity = '0';
            col.style.transform = 'translateY(-10px)';
        });

        await new Promise(resolve => setTimeout(resolve, 500));

        logoContainer.innerHTML = '';
        const currentWord = words[wordIndex];

        [...currentWord].forEach((char, index) => {
            const column = document.createElement('div');
            column.className = 'column';

            for (let i = 0; i < 4; i++) {
                const span = document.createElement('span');
                span.textContent = char;
                column.appendChild(span);
            }
            logoContainer.appendChild(column);

            setTimeout(() => {
                column.classList.add('active');
            }, index * 100);
        });

        wordIndex = (wordIndex + 1) % words.length;
    }

    smoothChangeWord();
    setInterval(smoothChangeWord, 3000);
</script>

</body>
</html>