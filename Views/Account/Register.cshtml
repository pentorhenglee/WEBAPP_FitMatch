@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Account.css" asp-append-version="true" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">


</head>
<body>
<div class="container">
    <div class="hero-section">
            <p class="tagline">IT'S TIME TO</p>
            <div id="dynamic-logo" class="run-logo"></div>
    </div>

    <div class="form-section">
        <div class="register-card">
            <h2 class="card">Register</h2>
            <div id="errorMessage" role="alert" class="error d-none"></div>
            <form id="registerForm">
                <label>Email</label>
                <div class="input-group">
                    <i class="fa-solid fa-envelope"></i>
                    <input type="email" id="email" placeholder="your@email.com" required />
                </div>

                <label>Username</label>
                <div class="input-group">
                    <i class="fa-solid fa-user"></i>
                    <input type="text" id="username" placeholder="Enter your username" required />
                </div>
                <label>Password</label>
                <div class="input-group">
                    <i class="fa-solid fa-lock"></i>
                    <input type="password" id="password" placeholder="Enter your password" required />
                </div>

                <button type="submit" id="btnSubmit" class="register-btn">
                    <span id="spinner"></span> REGISTER
                </button>
            </form>

            <p class="login-text">Already have an account? <a href="/Account/Login">Login here!</a></p>
        </div>
    </div>
</div>

<script>
    document.getElementById("registerForm").addEventListener("submit", async function (e) {
        e.preventDefault();
        
        const email = document.getElementById("email").value.trim();
        const username = document.getElementById("username").value.trim();
        const password = document.getElementById("password").value;
        const errorDiv = document.getElementById("errorMessage");
        const btnSubmit = document.getElementById("btnSubmit");
        const spinner = document.getElementById("spinner");

        // ล้างสถานะเดิม
        errorDiv.classList.add("d-none");
        btnSubmit.disabled = true;
        spinner.classList.remove("d-none");

        try {
            const res = await fetch("/api/auth/register", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ Email: email, Username: username, Password: password }) // Key ต้องตรงกับ DTO ใน Backend
            });

            if (res.ok) {
                // ถ้า Register สำเร็จ ส่งไปหน้า Index
                window.location.href = "/Home/Index";
            } else {
                // ถ้าไม่สำเร็จ ดึง Error message มาโชว์
                const errorData = await res.json(); 
                errorDiv.innerText = errorData.message || "Registration failed. Please check your inputs.";
                errorDiv.classList.remove("d-none");
            }
        } catch (err) {
            errorDiv.innerText = "Network error: " + err.message;
            errorDiv.classList.remove("d-none");
        } finally {
            btnSubmit.disabled = false;
            spinner.classList.add("d-none");
        }
    });

    const words = ["RUN", "CYCLE", "BASKETBALL", "SOCCER", "VOLLEYBALL"];
let wordIndex = 0;
const logoContainer = document.getElementById('dynamic-logo');

async function smoothChangeWord() {
    // 1. Fade out current letters
    const currentCols = logoContainer.querySelectorAll('.column');
    currentCols.forEach(col => {
        col.style.opacity = '0';
        col.style.transform = 'translateY(-10px)';
    });

    // 2. Short pause for fade out to complete
    await new Promise(resolve => setTimeout(resolve, 500));

    // 3. Clear and Build new word
    logoContainer.innerHTML = '';
    const currentWord = words[wordIndex];

    [...currentWord].forEach((char, index) => {
        const column = document.createElement('div');
        column.className = 'column';
        
        for (let i = 0; i < 4; i++) {
            const span = document.createElement('span');
            span.textContent = char;
            column.appendChild(span);
        }
        logoContainer.appendChild(column);

        // 4. Staggered Entrance (the "Smooth" part)
        setTimeout(() => {
            column.classList.add('active');
        }, index * 100); // 100ms delay between each letter
    });

    wordIndex = (wordIndex + 1) % words.length;
}

// Initial Run
smoothChangeWord();

// Interval (set slightly longer to account for animation time)
setInterval(smoothChangeWord, 3000);
</script>

</body>
</html>