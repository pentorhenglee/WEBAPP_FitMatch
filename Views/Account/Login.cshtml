    const words = ["RUN", "CYCLE", "BASKETBALL", "SOCCER", "VOLLEYBALL"];
let wordIndex = 0;
const logoContainer = document.getElementById('dynamic-logo');

function changeWord() {
    const currentWord = words[wordIndex];
    logoContainer.innerHTML = ''; // Clear previous word

    // Create a column for each letter
    [...currentWord].forEach((char, index) => {
        const column = document.createElement('div');
        column.className = 'column';
        
        // Stagger the entrance of each letter slightly
        column.style.animationDelay = `${index * 0.05}s`;

        // Create the 4 vertical repetitions
        for (let i = 0; i < 4; i++) {
            const span = document.createElement('span');
            span.textContent = char;
            column.appendChild(span);
        }

        logoContainer.appendChild(column);
    });

    // Cycle to next word
    wordIndex = (wordIndex + 1) % words.length;
}

// Initial Run
changeWord();

// Swap word every 3 seconds
setInterval(changeWord, 3000);

// Simple Form Logic
document.getElementById('loginForm').addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = document.querySelector('.login-btn');
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
    setTimeout(() => {
        alert("Login successful!");
        btn.innerHTML = "LOGIN";
    }, 1500);
});
</script>
</body>
</html>