@{
    ViewData["Title"] = "Welcome to FitMatch";
}

@section Styles {

    <link rel="stylesheet" href="~/css/Landing.css" asp-append-version="true"/>
}

// ref from account ดีกว่า ที่มันไม่ใช้ layout

<div class="landing-page container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4">Welcome to <span class="text-primary">FitMatch</span></h1>
        <p class="lead mt-3">Find workout buddies, join missions, and share your progress with a community that motivates you.</p>
    </div>

    <div class="row gy-4">
        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">What is FitMatch?</h2>
                    <p>FitMatch is a web app that helps you connect with other fitness enthusiasts, create and join missions, and track progress together.</p>
                    <p>Whether you want to practice, compete, or keep yourself accountable, FitMatch is built to make fitness social and fun.</p>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">How it works</h2>
                    <ul class="ps-3 mb-0">
                        <li><strong>Register or log in:</strong> Create an account to personalize your profile and start interacting.</li>
                        <li><strong>Create a mission:</strong> Set a goal, define the details, and invite others to join.</li>
                        <li><strong>Join missions:</strong> Browse available missions and request to join the ones that match your goals.</li>
                        <li><strong>Share updates:</strong> Post progress, comment, and support other members.</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h5">Get started</h2>
                    <p class="mb-2">It’s easy to begin:</p>
                    <ol class="ps-3 mb-0">
                        <li>Go to <a asp-controller="Account" asp-action="Register">Register</a> (or <a asp-controller="Account" asp-action="Login">Login</a> if you already have an account).</li>
                        <li>Complete your profile so others know your interests.</li>
                        <li>Visit the <a asp-controller="Dashboard" asp-action="Index">Dashboard</a> to explore missions and members.</li>
                    </ol>
                    <div class="mt-3">
                        <a class="btn btn-primary" asp-controller="Dashboard" asp-action="Index">Go to Dashboard</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5 text-center text-muted">
        <p class="mb-1">Need help? Visit the Help section or reach out via the contact information in your profile.</p>
        <p class="mb-0">Stay consistent, stay motivated — build habits with the FitMatch community!</p>
    </div>
</div>
