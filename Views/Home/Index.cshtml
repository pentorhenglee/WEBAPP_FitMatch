@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Home.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}

<div class="page-container">
    <div id="categorySidebar" class="category-sidebar">
        <div class="category-items-wrapper">
        
            <div class="category-item active" data-category="">
                <i class="fas fa-infinity"></i> <span class="category-label">ALL SPORTS</span>
            </div>
            <div class="category-item" data-category="Running">
                <i class="fas fa-running"></i> <span class="category-label">RUNNING</span>
            </div>
            <div class="category-item" data-category="Cycling">
                <i class="fas fa-bicycle"></i> <span class="category-label">CYCLING</span>
            </div>
            <div class="category-item" data-category="Basketball">
                <i class="fas fa-basketball-ball"></i> <span class="category-label">BASKETBALL</span>
            </div>
            <div class="category-item" data-category="Soccer">
                <i class="fas fa-futbol"></i> <span class="category-label">SOCCER</span>
            </div>
            <div class="category-item" data-category="Volleyball">
                <i class="fas fa-volleyball-ball"></i> <span class="category-label">VOLLEYBALL</span>
            </div>
        </div>
    </div>

    <!-- แถบ category มือถือ -->
    <div class="mobile-menu-container">
        <button class="mobile-menu-trigger" id="mobileMenuBtn">
            <i class="fas fa-bars"></i>
        </button>
        <div class="mobile-menu-items" id="mobileMenuItems">
            <div class="m-item active" data-category=""><i class="fas fa-infinity"></i></div>
            <div class="m-item" data-category="Running"><i class="fas fa-running"></i></div>
            <div class="m-item" data-category="Cycling"><i class="fas fa-bicycle"></i></div>
            <div class="m-item" data-category="Basketball"><i class="fas fa-basketball-ball"></i></div>
            <div class="m-item" data-category="Soccer"><i class="fas fa-futbol"></i></div>
        </div>
    </div>

    <div class="mission-sidebar" id="missionSidebar">
        <div class="mission-text-container">
            <span>M</span>
            <span>I</span>
            <span>S</span>
            <span>S</span>
            <span>I</span>
            <span>O</span>
            <span>N</span>
        </div>
        
        <!-- เอาเมาส์ไปชี้ที่ปุ่ม mission จะแสดง -->
        <div class="mission-content-hover">
            <div id="missionListContainer" class="mission-list"></div>
        </div>
    </div>

    <!-- กล่อง mission เมนูหน้ามือถือ -->
    <div class="mission-menu-container">
        <button class="mission-menu-trigger" id="mobileMissionBtn">
            <i class="fas fa-tasks"></i>
        </button>

        <div class="mission-menu-items" id="mobileMissionItems">
            <button class="close-mission-btn" id="closeMissionBtn">&times;</button>

            <div class="mobile-mission-header">YOUR MISSION</div>
            <div id="missionListContainerMobile" class="mission-list-mobile"></div>
        </div>
    </div>

    <!-- <div id="missionOverlay" class="mission-overlay"></div> -->

    <div class="fixes-top-section">
        <div class="welcome-message">
            <h1>Find Your Fitness <span>Community</span></h1>
        </div>
        
        <div class="search-container">
            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="SEARCH THE PLACE" />
                <button type="button" id="searchButton">SEARCH</button>
            </div>

            <div class="status-toggle-container">
                <label class="switch">
                    <input type="checkbox" id="statusToggle">
                    <span class="slider round">
                        <i class="fas fa-lock-open open-icon"></i>
                        <i class="fas fa-lock closed-icon"></i>
                    </span>
                </label>
                <!-- <span class="status-text" id="statusText">OPEN</span> -->
            </div>

            <button class="post-button" id="addpostButton">
            +
            </button>

        </div>
    </div>

    <!-- พื้นที่หลักของหน้าเว็บ -->
    <div class="main-content">
        <div id="postsDisplay" class="posts-display"></div> 
    </div>
</div>


<script>
    async function fetchMissions() { //ดึงข้อมูล mission จาก API
        const container = document.getElementById('missionListContainer'); 
        try {
            const response = await fetch('/api/MissionAPI/mission');
            if (!response.ok) throw new Error('Network response was not ok');
            
            const missions = await response.json();
            renderMissionList(missions); 

        } catch (error) {
            console.error('Error fetching missions:', error);
            if (container) {
                container.innerHTML = '<p style="color: #aaa; text-align: center;">Failed to load missions.</p>';
            }
        }
    }

    function renderMissionList(missions) {
        const container = document.getElementById('missionListContainer');
        const containerMobile = document.getElementById('missionListContainerMobile');
        
        // if (!container && !containerMobile) return;
        
        const html = missions.map(mission => `
            <div class="mission-item">
                <input type="checkbox" id="m-${mission.missionId}" 
                    ${mission.isCompleted ? 'checked' : ''} 
                    onchange="updateMissionStatus(${mission.missionId}, this.checked)">
                <label for="m-${mission.missionId}">${mission.description}</label>
            </div>
        `).join('');

        if (container) container.innerHTML = html;
        if (containerMobile) containerMobile.innerHTML = html;
    }

    async function updateMissionStatus(missionId, isCompleted) { //อัปเดตสถานะ mission ว่าติ๊กสำเร็จหรือยัง
        try {
            const response = await fetch('/api/MissionAPI/tick', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ missionId: missionId })
            });

            if (!response.ok) throw new Error('Update failed');

        } catch (error) {
            console.error('Update error:', error);
            alert('Failed to update mission status.');
            const checkbox = document.getElementById(`m-${missionId}`);
            if(checkbox) checkbox.checked = !isCompleted;
        }
    }

    function getSportIcon(sportType) { //กำหนด icon ของกีฬาบน Post
        const icons = {
            'Running': 'fa-running',
            'Cycling': 'fa-bicycle',
            'Basketball': 'fa-basketball-ball',
            'Soccer': 'fa-futbol',
            'Volleyball': 'fa-volleyball-ball'
        };
        return icons[sportType] || 'fa-infinity';
    }

    async function renderPosts(posts) { //สร้าง post ในหน้า home
        const postsDisplay = document.getElementById('postsDisplay');
        postsDisplay.innerHTML = ''; //ล้างข้อมมูลเก่า

        if (!posts || posts.length === 0) {
            postsDisplay.innerHTML = '<p class="no-posts">No posts found.</p>';
            return;
        }

        function getSportPlaceholder(sportType) { //ถ้าไม่มีรูปใช้รูปตามกีฬา
            const map = {
                'Running':    '/images/running_placeholder.jpg',
                'Soccer':     '/images/soccer_placeholder.jpg',
                'Basketball': '/images/basketball_placeholder.jpg',
                'Volleyball': '/images/volleyball_placeholder.jpg',
                'Cycling':    '/images/biking_placeholder.jpg',
            };
            return map[sportType] || '/images/placeholder-default.jpg';
        }

        posts.forEach(post => { //สร้าง card สำหรับแต่ละโพสต์(loop)
            const card = document.createElement('div');
            card.setAttribute('data-status', post.status || 'open');
            card.className = `post-card ${post.status === 'close' ? 'post-closed' : ''}`;

            const sportIconClass = getSportIcon(post.sportType);

            const eventDateTime = post.eventDateTime || 'TBA';
            const [date, time] = eventDateTime.includes('T') ? eventDateTime.split('T') : [eventDateTime, ''];

            const currentPeople = post.members ? post.members.length : 0; 
            const maxPeople = post.maxPeople || 0;
        
            card.innerHTML = `
                <div class="card-image">
                    <div class="sport-icon-badge">
                        <i class="fas ${sportIconClass}"></i>
                    </div>
                    <img src="${post.imageUrl || getSportPlaceholder(post.sportType)}" alt="${post.title || 'Post Image'}" />
                </div>
                
                <div class="card-content">
                    <h3 class="post-title">${post.title || 'Untitled'}</h3>
                    
                    <div class="post-meta-row">
                        <p class="post-location">
                            <i class="fas fa-map-marker-alt"></i> ${post.location || 'Unknown Location'}
                        </p>
                        <div class="post-datetime-container">
                            <p class="post-date">
                                <i class="fas fa-calendar-alt"></i> ${date}
                            </p>
                            ${time ? `<p class="post-time"><i class="fas fa-clock"></i> ${time.substring(0, 5)}</p>` : ''}
                        </div>
                    </div>
                    <p class="post-description">${post.description || ''}</p>

                    <div class="card-footer-info">
                        <span class="people-count">
                            <i class="fas fa-users"></i> ${currentPeople} / ${maxPeople}
                        </span>
                    </div>
                </div>
                `;

            card.addEventListener("click", function () { //ตรวจสอบสถานะของโพสต์ก่อนนำผู้ใช้ไปยังหน้ารายละเอียด
                if (post.status !== 'close') {
                    if (post.postId) {
                        window.location.href = `/Post/Detail?id=${post.postId}`;
                    }
                } else {
                    alert("This post is closed.");
                }
            });

            postsDisplay.appendChild(card);
        });
        document.getElementById('statusToggle').dispatchEvent(new Event('change'));
    }

    async function fetchSearchResults(query = null, category = null) { //เสิร์ช
        try {
            const params = new URLSearchParams();
            if (query && query.trim() !== "") params.append('query', query.trim());
            if (category && category.trim() !== "") params.append('category', category.trim());

            const queryString = params.toString();
            const url = `/api/all_post${queryString ? '?' + queryString : ''}`; 

            const response = await fetch(url);  //เช็คว่ามีโพสไหม
            if (!response.ok) throw new Error('Network response was not ok');
            
            const results = await response.json();

            renderPosts(results);

        } catch (error) {
            console.error('Error:', error);
            document.getElementById('postsDisplay').innerHTML = '<p class="no-post">No posts yet.</p>';
        }
    }

    document.getElementById('searchInput').addEventListener('keydown', function(event) { //เมื่อกด Enter จะเสอร์ช
        if (event.key === 'Enter') {
            event.preventDefault();
            const query = event.target.value; //ข้อความที่ผู้ใช้พิมพ์ค้นหา
            const activeCat = document.querySelector('.category-item.active')?.getAttribute('data-category') || ""; //เก็บ category ที่เลือกอยู่
            
            fetchSearchResults(query, activeCat);
        }
    });

    document.addEventListener('DOMContentLoaded', () => { //โหลดทุกอย่างเมื่อเปิดหน้าเว็บ
        fetchSearchResults(null);  //โหลดโพส
        fetchMissions(); //โหลด mission

        const closeBtn = document.getElementById('closeMissionBtn'); //โค้ดปิดในหน้า mission มือถือ
        if (closeBtn) {
            closeBtn.addEventListener('click', function(e) {
                e.stopPropagation();
                const items = document.getElementById('mobileMissionItems');
                const container = document.querySelector('.mission-menu-container');
                
                items.classList.remove('show');
                container.classList.remove('show-overlay');
            });
        }

        document.querySelectorAll('.category-item').forEach(item => { //กรอง category
            item.addEventListener('click', function() {
                document.querySelectorAll('.category-item').forEach(el => el.classList.remove('active'));
                this.classList.add('active');

                const category = this.getAttribute('data-category');
                const searchTerms = document.getElementById('searchInput').value;
                fetchSearchResults(searchTerms, category);
            });
        });
    
        const addPostBtn = document.getElementById("addpostButton"); //ปุ่ม add post(+)
        if (addPostBtn) {
            addPostBtn.addEventListener("click", function () {
                window.location.href = "/Post/Create";
            });
        }
    });

    document.getElementById('searchButton').addEventListener('click', () => { //ปุ่ม Search
        const query = document.getElementById('searchInput').value;
        const activeCat = document.querySelector('.category-item.active')?.getAttribute('data-category') || "";
        
        fetchSearchResults(query, activeCat);
    });

    document.getElementById('mobileMenuBtn').addEventListener('click', function() { //เปิด / ปิด category ในมือถือ
        document.getElementById('mobileMenuItems').classList.toggle('show');
    });

    document.querySelectorAll('.m-item').forEach(item => { //ย้ายแถบเขียวใน category หน้ามือถือ
        item.addEventListener('click', function() {
            document.querySelectorAll('.m-item').forEach(el => el.classList.remove('active'));
            this.classList.add('active');
            
            const category = this.getAttribute('data-category');
            const searchTerms = document.getElementById('searchInput').value;
            fetchSearchResults(searchTerms, category);
            document.getElementById('mobileMenuItems').classList.remove('show'); //menu จะปิดเอง
        });
    });

    document.getElementById('mobileMissionBtn').addEventListener('click', function(e) { //ปุ่มเปิด mission มือถือ
        e.stopPropagation();
        const items = document.getElementById('mobileMissionItems');
        const container = document.querySelector('.mission-menu-container');
        
        items.classList.toggle('show');
        container.classList.toggle('show-overlay'); 
    });

    document.addEventListener('click', function(e) { //ปุ่มปิดหน้า mission เมื่อกดตรงไหนก้ได้ในหน้าเว็บ
        const items = document.getElementById('mobileMissionItems');
        const container = document.querySelector('.mission-menu-container');
        
        if (items.classList.contains('show') && !items.contains(e.target)) {
            items.classList.remove('show');
            container.classList.remove('show-overlay');
        }
    });

    // document.getElementById("missionOverlay").onclick = function(){
    //     document.querySelector(".mission-menu-items").classList.remove("show");
    //     this.classList.remove("show");
    // }

    document.getElementById('statusToggle').addEventListener('change', function() { //toggle close or open
        const isChecked = this.checked;
        const targetStatus = isChecked ? 'close' : 'open';
        const label = document.getElementById('statusText');

        const allCards = document.querySelectorAll('.post-card');
        allCards.forEach(card => {
            const cardStatus = card.getAttribute('data-status');
            
            if (cardStatus === targetStatus) {
                card.style.display = "block";
            } else {
                card.style.display = "none";
            }
        });
    });
</script>
