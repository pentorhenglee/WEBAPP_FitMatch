@{
    ViewData["Title"] = "Home Page";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Home.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}

<div class="page-container">
    <div id="categorySidebar" class="category-sidebar">
        <div class="category-items-wrapper">
            <div class="category-item active" data-category="">
                <i class="fas fa-infinity"></i> <span class="category-label">ALL SPORTS</span>
            </div>
            <div class="category-item" data-category="Running">
                <i class="fas fa-running"></i> <span class="category-label">RUNNING</span>
            </div>
            <div class="category-item" data-category="Cycling">
                <i class="fas fa-bicycle"></i> <span class="category-label">CYCLING</span>
            </div>
            <div class="category-item" data-category="Basketball">
                <i class="fas fa-basketball-ball"></i> <span class="category-label">BASKETBALL</span>
            </div>
            <div class="category-item" data-category="Soccer">
                <i class="fas fa-futbol"></i> <span class="category-label">SOCCER</span>
            </div>
            <div class="category-item" data-category="Volleyball">
                <i class="fas fa-volleyball-ball"></i> <span class="category-label">VOLLEYBALL</span>
            </div>
        </div>
    </div>

    <div class="mission-sidebar" id="missionSidebar">
        <div class="mission-text-container">
            <span>M</span>
            <span>I</span>
            <span>S</span>
            <span>S</span>
            <span>I</span>
            <span>O</span>
            <span>N</span>
        </div>
        
        <div class="mission-content-hover">
            <div id="missionListContainer" class="mission-list">
            </div>
        </div>
    </div>

    <div class="fixes-top-section">
        <div class="welcome-message">
            <h1>Find Your Fitness Community</h1>
        </div>
        
        <div class="search-container">
            <div class="search-bar">
                <input type="text" id="searchInput" placeholder="SEARCH THE PLACE" />
                <button type="button" id="searchButton">SEARCH</button>
            </div>

            <button class="post-button" id="addpostButton">
            +
            </button>
        </div>
    </div>

    <div class="main-content">
        <div id="postsDisplay" class="posts-display"></div>
    </div>
</div>


<script>
    async function fetchMissions() {
        const container = document.getElementById('missionListContainer'); 
        try {
            const response = await fetch('/api/missions');
            if (!response.ok) throw new Error('Network response was not ok');
            
            const missions = await response.json();
            renderMissionList(missions); 

        } catch (error) {
            console.error('Error fetching missions:', error);
            if (container) {
                container.innerHTML = '<p style="color: #aaa; text-align: center;">Failed to load missions.</p>';
            }
        }
    }

    async function updateMissionStatus(missionId, isCompleted) {
        try {
            const response = await fetch(`/api/missions/${missionId}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ isCompleted: isCompleted }) 
            });

            if (!response.ok) throw new Error('Update failed');
            console.log(`Mission ${missionId} updated to ${isCompleted}`);

        } catch (error) {
            console.error('Update error:', error);
            alert('Failed to update mission status.');
            // คืนค่า checkbox กลับไปสถานะเดิมถ้าล้มเหลว
            const checkbox = document.getElementById(`m-${missionId}`);
            if(checkbox) checkbox.checked = !isCompleted;
        }
    }

    function renderMissionList(missions) {
        const container = document.getElementById('missionListContainer');
        if (!container) return;
        
        container.innerHTML = ''; 

        missions.forEach(mission => {
            const item = document.createElement('div');
            item.className = 'mission-item';
            
            item.innerHTML = `
                <input type="checkbox" id="m-${mission.id}" 
                    ${mission.isCompleted ? 'checked' : ''} 
                    onchange="updateMissionStatus(${mission.id}, this.checked)">
                <label for="m-${mission.id}">${mission.title}</label>
            `;
            container.appendChild(item);
        });
    }

    async function renderPosts(posts) {
        const postsDisplay = document.getElementById('postsDisplay');
        postsDisplay.innerHTML = '';

        if (!posts || posts.length === 0) {
            postsDisplay.innerHTML = '<p class="no-posts">No posts found.</p>';
            return;
        }

        posts.forEach(post => {
            const card = document.createElement('div');
            card.className = 'post-card';

            card.innerHTML = `
                <div class="card-image">
                    <img src="${post.imageUrl || '/images/default-post.jpg'}" alt="${post.title || 'Post Image'}" />
                </div>
                <div class="card-content">
                    <h3 class="post-title">${post.title || 'Untitled'}</h3>
                    
                    <div class="post-meta-row">
                        <p class="post-location">
                            <i class="fas fa-map-marker-alt"></i> ${post.location || 'Unknown Location'}
                        </p>
                        <p class="post-date">
                            <i class="fas fa-calendar-alt"></i> ${post.eventDateTime || 'TBA'}
                        </p>
                    </div>
                    <p class="post-description">${post.description || ''}</p>
                </div>

                <div class="card-footer">
                    <button class="view-more-btn" data-post-id="${post.postId}">View More</button>
                </div>
                `;

            const viewMoreBtn = card.querySelector(".view-more-btn");
            viewMoreBtn.addEventListener("click", function (e) {
                e.stopPropagation();
                const id = this.getAttribute("data-post-id"); 
                if (id) {
                    window.location.href = `/Post/Detail?id=${id}`;
                }
            });

            postsDisplay.appendChild(card);
        });
    }

    async function fetchSearchResults(query = null, category = null) {
        try {
            const params = new URLSearchParams();
            if (query && query.trim() !== "") params.append('query', query.trim());
            if (category && category.trim() !== "") params.append('category', category.trim());

            const queryString = params.toString();
            const url = `/api/all_post${queryString ? '?' + queryString : ''}`;

            const response = await fetch(url);
            if (!response.ok) throw new Error('Network response was not ok');
            
            const results = await response.json();

            renderPosts(results);

        } catch (error) {
            console.error('Error:', error);
            document.getElementById('postsDisplay').innerHTML = '<p class="no-post">No posts yet.</p>';
        }
    }

    // เมื่อโหลดหน้าเว็บ: เรียกโดยไม่ส่งค่า (ดึงทั้งหมด)
    document.addEventListener('DOMContentLoaded', () => {
        fetchSearchResults(null); 
        fetchMissions();
    });

    document.getElementById('searchButton').addEventListener('click', () => {
        const query = document.getElementById('searchInput').value;
        // หาหมวดหมู่ที่ถูกเลือกอยู่ในขณะนั้น (ตัวที่มีคลาส active)
        const activeCat = document.querySelector('.category-item.active')?.getAttribute('data-category') || "";
        
        // เรียกฟังก์ชันโดยส่งทั้งคำค้นหาและหมวดหมู่ (แม้ query จะว่างก็ตาม)
        fetchSearchResults(query, activeCat);
    });

    document.getElementById('searchInput').addEventListener('keydown', function(event) {
        if (event.key === 'Enter') {
            event.preventDefault();
            const query = event.target.value;
            const activeCat = document.querySelector('.category-item.active')?.getAttribute('data-category') || "";
            
            fetchSearchResults(query, activeCat);
        }
    });

    document.addEventListener('DOMContentLoaded', () => {
    // จัดการการคลิกเลือกหมวดหมู่
        document.querySelectorAll('.category-item').forEach(item => {
            item.addEventListener('click', function() {
                // 1. ย้ายไฮไลท์สีเขียว
                document.querySelectorAll('.category-item').forEach(el => el.classList.remove('active'));
                this.classList.add('active');

                // 2. กรองข้อมูล
                const category = this.getAttribute('data-category');
                const searchTerms = document.getElementById('searchInput').value;
                fetchSearchResults(searchTerms, category);
            });
        });
    });

    document.addEventListener("DOMContentLoaded", function () {
        document.getElementById("addpostButton")
            .addEventListener("click", function () {
                window.location.href = "/Post/Create";
            });
    });
</script>