@{
    ViewData["Title"] = "Dashboard";
}

@section Styles {
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}

<div class="dashboard-container">
    
    <div class="dash-left-panel">
        <div class="dash-header">
            <h2>Dashboard</h2>
            <div style="font-size: 0.8rem; color: var(--text-muted);">
                Sort: <select style="background:transparent; color:rgb(203, 203, 203); border:none; outline:none;"><option>Last Month</option></select>
            </div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('upcoming', this)">Up Coming</button>
            <button class="tab-btn" onclick="switchTab('history', this)">History</button>
        </div>

        <div id="upcoming-content" class="tab-content active">
            <div class="loading-text">Loading...</div>
        </div>

        <div id="history-content" class="tab-content">
            <div class="loading-text">Loading...</div>
        </div>
    </div>

    <div class="dash-right-panel">
        <div class="stats-grid">
            
            <div class="stat-card">
                <h3>Participated Rate</h3>
                <div class="stat-main-val" id="partCount">0</div>
                <div class="stat-sub-val" id="partTarget">0 / 30</div>
                <div class="progress-bg">
                    <div class="progress-fill" id="partProgress" style="width: 0%;"></div>
                </div>
            </div>

            <div class="stat-card">
                <h3>Activity Stats</h3>
                <div style="display: flex; align-items: center; justify-content: space-around; gap: 15px; padding: 10px;">
                    <canvas id="activityChart" width="140" height="140"></canvas>
                    
                    <div id="chartLegend" style="display: flex; flex-direction: column; gap: 8px; font-size: 0.8rem; color: #fff; text-align: left; min-width: 100px;">
                        </div>
                </div>
            </div>

            <div class="stat-card">
                <h3>Favorite Partners</h3>
                <div id="partnersContainer">
                    <div class="loading-text">Loading partners...</div>
                </div>
            </div>

            <div class="stat-card">
                <div class="stat-header-flex">
                    <h3>Mission Succeeded</h3>
                    <button style="background:none; border:none; color:white; cursor:pointer;"><i class="fa-solid fa-plus"></i></button>
                </div>
                <div class="stat-main-val" id="missionCount" style="text-align: left;">0 <span style="font-size:1rem; color:#aaa;" id="missionTotal">/ 0</span></div>
                <div class="progress-bg" style="margin-bottom: 15px;">
                    <div class="progress-fill" id="missionProgress" style="width: 0%;"></div>
                </div>
                <div id="missionsContainer">
                    <div class="loading-text">Loading missions...</div>
                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {

    <script>
        // ==========================================
        // 1. Utilities
        // ==========================================
        function getSportIcon(sportType) {
            const type = (sportType || "").toLowerCase();
            if (type.includes("run")) return "fa-person-running";
            if (type.includes("soccer") || type.includes("football")) return "fa-futbol";
            if (type.includes("basket")) return "fa-basketball";
            if (type.includes("volleyball")) return "fa-volleyball";
            if (type.includes("cycl") || type.includes("bike")) return "fa-person-biking";
            return "fa-infinity"; 
        }

        // ==========================================
        // 2. Render Left Panel (Activities)
        // ==========================================
        function renderCards(containerId, events, emptyMessage) {
            const container = document.getElementById(containerId);
            container.innerHTML = ''; 

            if (!events || events.length === 0) {
                container.innerHTML = `
                    <div style="text-align: center; color: var(--text-muted); padding: 40px 0;">
                        <i class="fa-solid fa-clock-rotate-left" style="font-size: 2rem; margin-bottom: 10px;"></i>
                        <p>${emptyMessage}</p>
                    </div>`;
                return;
            }

            let htmlContent = '';
            events.forEach(ev => {
                const dateObj = new Date(ev.eventDateTime);
                const dateStr = dateObj.toLocaleDateString('en-GB').replace(/\//g, ' - '); 
                const timeStr = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
                const iconClass = getSportIcon(ev.sportType);

                htmlContent += `
                    <div class="event-card" onclick="window.location.href='/Post/Detail?id=${ev.postId}'" style="cursor: pointer;">
                        <div class="event-icon"><i class="fa-solid ${iconClass}"></i></div>
                        <div class="event-info">
                            <h4>${(ev.location || "UNKNOWN").toUpperCase()}</h4>
                            <div class="event-time">${dateStr} • ${timeStr}</div>
                            <div class="event-desc">${ev.title}</div>
                        </div>
                        <div class="event-arrow"><i class="fa-solid fa-chevron-right"></i></div>
                    </div>
                `;
            });
            container.innerHTML = htmlContent;
        }

        async function fetchMyActivities() {
            try {
                const response = await fetch('/api/dashboard/my-activities');
                if (!response.ok) throw new Error("Failed to load activities");
                const data = await response.json();

                renderCards('upcoming-content', data.upcoming, 'No upcoming!');
                renderCards('history-content', data.history, 'No History!<br><span style="font-size: 0.8rem;">(Event ended will show here!)</span>');
                
            } catch (error) {
                console.error(error);
                document.getElementById('upcoming-content').innerHTML = "<div class='loading-text' style='color:#ff4d4d;'>Error Loading Data</div>";
                document.getElementById('history-content').innerHTML = "<div class='loading-text' style='color:#ff4d4d;'>Error Loading Data</div>";
            }
        }

        // ==========================================
        // 3. Render Right Panel (Stats)
        // ==========================================
        async function fetchDashboardStats() {
            try {
                const response = await fetch('/api/dashboard/stats');
                if (!response.ok) throw new Error("Failed to load stats");
                const data = await response.json();

                // --- Participated Rate ---
                document.getElementById('partCount').innerText = data.participated;
                document.getElementById('partTarget').innerText = `${data.participated} / ${data.targetParticipated}`;
                let partPercent = (data.participated / data.targetParticipated) * 100;
                document.getElementById('partProgress').style.width = `${Math.min(partPercent, 100)}%`;

                // --- Activity Stats (Chart) ---
                renderChart(data.activityStats);

                // --- Favorite Partners ---
                const partnersDiv = document.getElementById('partnersContainer');
                partnersDiv.innerHTML = '';
                if(data.favoritePartners.length === 0) {
                    partnersDiv.innerHTML = '<div class="loading-text">No partners yet</div>';
                } else {
                    data.favoritePartners.forEach(p => {
                        partnersDiv.innerHTML += `
                            <div class="partner-item">
                                <img src="${p.profileUrl}" alt="${p.username}">
                                <div style="flex-grow: 1;">
                                    <div style="font-weight: bold; font-size: 0.9rem; color: #fff;">${p.username}</div>
                                    <div style="font-size: 0.75rem; color: #aaa;">Met ${p.meetCount} times</div>
                                </div>
                            </div>
                        `;
                    });
                }

                // --- Missions Succeeded ---
                const missionsDiv = document.getElementById('missionsContainer');
                missionsDiv.innerHTML = '';
                let completedMissions = 0;
                let totalMissions = data.missions.length;

                if(totalMissions === 0) {
                    missionsDiv.innerHTML = '<div class="loading-text">No missions added</div>';
                } else {
                    data.missions.forEach(m => {
                        if(m.isCompleted) completedMissions++;
                        const isChecked = m.isCompleted ? 'checked' : '';
                        const textStyle = m.isCompleted ? 'text-decoration: line-through; color: #888;' : 'color: #fff;';
                        
                        missionsDiv.innerHTML += `
                            <div class="mission-item">
                                <input type="checkbox" ${isChecked} disabled>
                                <span style="${textStyle}">${m.description}</span>
                            </div>
                        `;
                    });
                }
                
                const maxMissionTarget = Math.max(totalMissions, 12); // Defualt target is 12 if less
                document.getElementById('missionCount').innerHTML = `${completedMissions} <span class="stat-sub-inline" style="font-size:1rem; color:#aaa;" id="missionTotal">/ ${maxMissionTarget}</span>`;
                let missionPercent = (completedMissions / maxMissionTarget) * 100;
                document.getElementById('missionProgress').style.width = `${Math.min(missionPercent, 100)}%`;

            } catch (error) {
                console.error("Error loading stats:", error);
                document.getElementById('partnersContainer').innerHTML = "<div class='loading-text' style='color:#ff4d4d;'>Failed to load stats</div>";
            }
        }

        function renderChart(statsData) {
            const canvas = document.getElementById('activityChart');
            if (!canvas) return;
            const ctx = canvas.getContext('2d');
            const legendContainer = document.getElementById('chartLegend');
            
            // ชุดสีที่ดูทันสมัยสไตล์ Dashboard (แตกต่างกันชัดเจนและดูพรีเมียม)
            const colors = ['#28a745', '#007bff', '#ffc107', '#dc3545', '#20c997', '#fd7e14'];
            
            const dataValues = statsData.map(s => s.count);
            const labels = statsData.map(s => s.sport);
            const total = dataValues.reduce((a, b) => a + b, 0);

            ctx.clearRect(0, 0, canvas.width, canvas.height);
            legendContainer.innerHTML = '';

            if (total === 0) {
                ctx.beginPath();
                ctx.arc(canvas.width / 2, canvas.height / 2, 60, 0, 2 * Math.PI);
                ctx.fillStyle = '#333';
                ctx.fill();
                legendContainer.innerHTML = '<span style="color:#aaa;">No Data</span>';
                return;
            }

            let startAngle = -Math.PI / 2;
            const centerX = canvas.width / 2;
            const centerY = canvas.height / 2;
            const radius = 65;

            dataValues.forEach((value, i) => {
                const sliceAngle = (value / total) * 2 * Math.PI;
                const color = colors[i % colors.length];

                // วาดชิ้นเค้ก (Pie Slice)
                ctx.beginPath();
                ctx.moveTo(centerX, centerY); // เริ่มจากจุดศูนย์กลางเพื่อให้เป็นรูปพัด
                ctx.arc(centerX, centerY, radius, startAngle, startAngle + sliceAngle);
                ctx.closePath();
                
                ctx.fillStyle = color;
                ctx.fill();

                // เพิ่มคำอธิบายด้านข้าง
                const legendItem = `
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <div style="width: 10px; height: 10px; background: ${color}; border-radius: 2px;"></div>
                        <span style="white-space: nowrap;">${labels[i]}</span>
                    </div>`;
                legendContainer.innerHTML += legendItem;

                startAngle += sliceAngle;
            });
        }

        // ฟังก์ชันช่วยวาดวงกลมพื้นฐาน
        function drawCircle(ctx, x, y, radius, start, end, color) {
            ctx.beginPath();
            ctx.arc(x, y, radius, start, end);
            ctx.fillStyle = color;
            ctx.fill();
        }

        // ==========================================
        // 4. Initialization
        // ==========================================
        function switchTab(tabId, btnElement) {
            document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
            btnElement.classList.add('active');

            document.querySelectorAll('.tab-content').forEach(content => content.classList.remove('active'));
            document.getElementById(tabId + '-content').classList.add('active');
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetchMyActivities(); // Load left panel
            fetchDashboardStats(); // Load right panel
        });
    </script>
}