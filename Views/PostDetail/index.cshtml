@{
    ViewData["Title"] = "Post Detail";
}

@section Styles {
    <link rel="stylesheet" href="~/css/PostDetail.css" asp-append-version="true" />
}

<div class="post-detail-container">
    
    <div class="post-chat-section">
        <div class="chat-header">Chat</div>
        
        <div class="chat-messages" id="chatHistoryContainer">
            <div style="text-align:center; color:#ccc; font-size:0.8rem; margin-top:20px;">Loading chat...</div>
        </div>

        <div class="chat-input-area">
            <input type="text" id="chatInputMessage" placeholder="Type a message..." onkeypress="handleEnterKey(event)" />
            <button onclick="sendChatMessage()" style="background:none; border:none; color:white; cursor:pointer;">
                <i class="fa-solid fa-paper-plane"></i>
            </button>
        </div>
    </div>

    <div class="post-info-section">
        <img src="" id="displayCoverImg" class="post-cover-img" alt="Event Cover" style="display:none;" />
        
        <div class="post-details">
            <h2 id="displayTitle">Loading...</h2>
            <div class="post-meta" id="displayMeta">Location | Date | Time</div>
            <div class="post-desc" id="displayDesc">Please wait, fetching data from database...</div>
            
            <div style="margin-top:20px; font-weight:bold; color: var(--accent);" id="displayParticipants">
                Participants: - / -
            </div>
        </div>

        <div class="join-btn-container">
            <button class="btn-join" id="btnJoin" onclick="joinPost()">JOIN</button>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const currentPostId = 1; 
        const currentUserId = 99; // ไอดีคนกำลังล็อกอิน
        const myAvatarUrl = ""; // รูปตัวเอง

        // 1. Mockup Data (เพิ่มข้อมูลชื่อและรูปภาพ)
        const mockPostFromDB = {
            PostId: 1,
            Title: "Morning Run at Suan Lumpini",
            Location: "Suan Lumpini", 
            Date: "14 Feb 2026",
            Time: "08:00",
            Description: "Looking for running group. Pace doesn't matter, we can chill and take photos. Everyone is welcome!",
            MaxPeople: 5,
            CurrentPeople: 2,
            ImageUrl: "https://upload.wikimedia.org/wikipedia/commons/3/3e/Aerial_view_of_Lumphini_Park.jpg"
        };

        const mockChatsFromDB = [
            { 
                CommentId: 1, 
                UserId: 10, 
                UserName: "John Runner", 
                AvatarUrl: "", 
                Message: "Anyone arrived yet?", 
                IsMine: false 
            },
            { 
                CommentId: 2, 
                UserId: 99, 
                UserName: "Earthy", 
                AvatarUrl: myAvatarUrl, 
                Message: "Driving there, 10 mins away!", 
                IsMine: true 
            }
        
        ];

        // 2. Fetch API Methods
        async function fetchPostDetail() {
            try {
                const data = mockPostFromDB; 
                document.getElementById('displayCoverImg').src = data.ImageUrl;
                document.getElementById('displayCoverImg').style.display = "block";
                document.getElementById('displayTitle').innerText = data.Title;
                document.getElementById('displayMeta').innerText = `${data.Location} | ${data.Date} | ${data.Time}`;
                document.getElementById('displayDesc').innerText = data.Description;
                document.getElementById('displayParticipants').innerText = `Participants: ${data.CurrentPeople} / ${data.MaxPeople}`;
            } catch (error) { console.error("Error:", error); }
        }

        async function fetchChatHistory() {
            try {
                const chats = mockChatsFromDB; 
                const chatContainer = document.getElementById('chatHistoryContainer');
                chatContainer.innerHTML = ""; 

                chats.forEach(chat => {
                    const wrapperClass = chat.IsMine ? "mine" : "others";
                    chatContainer.innerHTML += `
                        <div class="chat-message-wrapper ${wrapperClass}">
                            <img src="${chat.AvatarUrl}" class="chat-avatar" alt="Avatar">
                            <div class="chat-message-content">
                                <div class="chat-username">${chat.UserName}</div>
                                <div class="chat-bubble">${chat.Message}</div>
                            </div>
                        </div>
                    `;
                });
                chatContainer.scrollTop = chatContainer.scrollHeight;
            } catch (error) { console.error("Error:", error); }
        }

        async function sendChatMessage() {
            const input = document.getElementById('chatInputMessage');
            const message = input.value.trim();
            if (!message) return;

            try {
                // สร้างแชทใหม่ฝั่งตัวเองทันทีเมื่อกดส่ง
                const chatContainer = document.getElementById('chatHistoryContainer');
                chatContainer.innerHTML += `
                    <div class="chat-message-wrapper mine">
                        <img src="${myAvatarUrl}" class="chat-avatar" alt="Avatar">
                        <div class="chat-message-content">
                            <div class="chat-username">Earthy</div>
                            <div class="chat-bubble">${message}</div>
                        </div>
                    </div>
                `;
                chatContainer.scrollTop = chatContainer.scrollHeight;
                input.value = ""; 
            } catch (error) {
                alert("Failed to send message.");
            }
        }

        function handleEnterKey(e) {
            if (e.key === 'Enter') sendChatMessage();
        }

        async function joinPost() {
            const btn = document.getElementById('btnJoin');
            btn.innerText = "JOINING...";
            btn.disabled = true;

            setTimeout(() => {
                btn.innerText = "JOINED";
                btn.style.backgroundColor = "var(--accent)";
                btn.style.color = "white";
                document.getElementById('displayParticipants').innerText = `Participants: 3 / 5`;
            }, 1000);
        }

        document.addEventListener('DOMContentLoaded', () => {
            fetchPostDetail();
            fetchChatHistory();
        });
    </script>
}