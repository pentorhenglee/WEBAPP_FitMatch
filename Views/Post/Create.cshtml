@{
    ViewData["Title"] = "Create Post";
}

@section Styles {
    <link rel="stylesheet" href="~/css/PostCreate.css" asp-append-version="true" />
}

<div class="create-post-wrapper">
    <div class="create-post-container">
        <h2>Create <span>New Activity</span></h2>
        
        <form id="createPostForm">
            <div class="form-grid">
                
                <div class="form-group full-width">
                    <label>Activity Title</label>
                    <input type="text" id="postTitle" placeholder="e.g. Morning Run at Suan Lumpini" required />
                </div>

                <div class="form-group">
                    <label>Sport Type</label>
                    <select id="postSportType" required>
                        <option value="" disabled selected>Select sport...</option>
                        <option value="Running">Running</option>
                        <option value="Soccer">Soccer</option>
                        <option value="Basketball">Basketball</option>
                        <option value="Volleyball">Volleyball</option>
                        <option value="Cycling">Cycling</option>
                    </select>
                </div>

                <div class="form-group">
                    <label>Max People</label>
                    <input type="number" id="postMaxPeople" min="2" max="50" placeholder="e.g. 5" required />
                </div>

                <div class="form-group full-width">
                    <label>Location</label>
                    <div class="location-search-row">
                        <input type="text" id="postLocation" placeholder="e.g. Suan Lumpini Park" required />
                        <button type="button" id="btnSearchLocation" class="btn-search-location">Search Location</button>
                    </div>
                    <input type="hidden" id="postLat" />
                    <input type="hidden" id="postLon" />
                    <p id="locationStatus" class="location-status-text"></p>
                </div>

                <div class="form-group full-width" id="mapPreviewSection" style="display:none;">
                    <label>Confirm Location</label>
                    <iframe id="mapPreviewIframe"
                        width="100%"
                        height="300"
                        style="border:0; border-radius:8px;"
                        loading="lazy"
                        src="">
                    </iframe>
                </div>

                <div class="form-group">
                    <label>Date</label>
                    <input type="date" id="postDate" lang="en-GB" required />
                </div>

                <div class="form-group">
                    <label>Time</label>
                    <input type="time" id="postTime" required />
                </div>

                <div class="form-group full-width" id="weatherSection" style="display:none;">
                    <label>Weather Forecast</label>
                    <div id="weatherCard" class="weather-card">
                        <p id="weatherLoading"><i class="fas fa-spinner fa-spin"></i> Fetching weather data...</p>
                        <div id="weatherResult" style="display:none;">
                            <span id="weatherIcon" class="weather-icon"></span>
                            <div class="weather-info">
                                <span id="weatherTemp"></span>
                                <span id="weatherDesc"></span>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group full-width">
                    <label>Cover Image URL (Optional)</label>
                    <input type="url" id="postImageUrl" placeholder="" />
                </div>

                <div class="form-group full-width">
                    <label>Description</label>
                    <textarea id="postDescription" rows="4" placeholder="Share more details about your activity..." required></textarea>
                </div>

            </div>

            <button type="submit" class="btn-submit-post" id="btnSubmitPost">CREATE POST</button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        //Set minimum date
        const todayStr = new Date().toISOString().split('T')[0];
        document.getElementById('postDate').min = todayStr;

        //Geocode (lat,lon) Nominatim
        document.getElementById('btnSearchLocation').addEventListener('click', async function () {
            const query = document.getElementById('postLocation').value.trim();
            if (!query) { alert('Please fill the Location first!'); sturn; }

            const statusEl = document.getElementById('locationStatus');
            statusEl.textContent = 'Loading...';

            try {
                const res = await fetch(
                    `https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(query)}&format=json&limit=1`,
                    { headers: { 'User-Agent': 'FitMatch-App' } }
                );
                const data = await res.json();

                if (!data.length) {
                    statusEl.textContent = 'Not found, fill again please';
                    return;
                }

                const lat = parseFloat(data[0].lat);
                const lon = parseFloat(data[0].lon);
                const displayName = data[0].display_name;

                document.getElementById('postLat').value = lat;
                document.getElementById('postLon').value = lon;
                statusEl.textContent = `Found: ${displayName}`;

                // Update map iframe
                const mapSection = document.getElementById('mapPreviewSection');
                const iframe = document.getElementById('mapPreviewIframe');
                iframe.src = `https://maps.google.com/maps?q=${lat},${lon}&z=15&output=embed`;
                mapSection.style.display = 'block';

                // Trigger weather if date already selected
                const dateVal = document.getElementById('postDate').value;
                if (dateVal) fetchWeather(lat, lon, dateVal);

            } catch (err) {
                statusEl.textContent = 'Error Try Again!';
                console.error(err);
            }
        });

        // Weather Open-Meteo
        async function fetchWeather(lat, lon, dateStr) {
            const weatherSection = document.getElementById('weatherSection');
            const weatherLoading = document.getElementById('weatherLoading');
            const weatherResult  = document.getElementById('weatherResult');

            weatherSection.style.display = 'block';
            weatherLoading.style.display = 'block';
            weatherResult.style.display  = 'none';

            try {
                const url = `https://api.open-meteo.com/v1/forecast` +
                    `?latitude=${lat}&longitude=${lon}` +
                    `&daily=temperature_2m_max,temperature_2m_min,precipitation_sum,weathercode` +
                    `&timezone=Asia%2FBangkok` +
                    `&start_date=${dateStr}&end_date=${dateStr}`;

                const res  = await fetch(url);
                const data = await res.json();

                if (!data.daily || !data.daily.time.length) {
                    weatherLoading.textContent = 'Can not forecast (Weather can not forecast more than 16 days)';
                    return;
                }

                const maxTemp = data.daily.temperature_2m_max[0];
                const minTemp = data.daily.temperature_2m_min[0];
                const rain    = data.daily.precipitation_sum[0];
                const code    = data.daily.weathercode[0];

                document.getElementById('weatherIcon').textContent = weatherCodeToIcon(code);
                document.getElementById('weatherTemp').textContent = `${minTemp}°C – ${maxTemp}°C`;
                document.getElementById('weatherDesc').textContent = `Rain ${rain} mm  |  ${weatherCodeToDesc(code)}`;

                weatherLoading.style.display = 'none';
                weatherResult.style.display  = 'flex';

            } catch (err) {
                weatherLoading.textContent = 'Unsuccess to download data';
                console.error(err);
            }
        }

        function weatherCodeToIcon(code) {
            if (code === 0) return '☀️';
            if (code <= 2)  return '🌤️';
            if (code <= 3)  return '☁️';
            if (code <= 48) return '🌫️';
            if (code <= 57) return '🌦️';
            if (code <= 67) return '🌧️';
            if (code <= 77) return '❄️';
            if (code <= 82) return '🌧️';
            if (code <= 99) return '⛈️';
            return '🌡️';
        }

        function weatherCodeToDesc(code) {
            if (code === 0)  return 'Clear Sky';
            if (code <= 2)   return 'Partly Cloudy';
            if (code <= 3)   return 'Overcast';
            if (code <= 48)  return 'Foggy';
            if (code <= 57)  return 'Drizzle';
            if (code <= 67)  return 'Rain';
            if (code <= 77)  return 'Snow';
            if (code <= 82)  return 'Heavy Rain';
            if (code <= 99)  return 'Thunderstorm';
            return 'Unknown';
        }

        // Re-fetch weather when date changes
        document.getElementById('postDate').addEventListener('change', function() {
            const lat = document.getElementById('postLat').value;
            const lon = document.getElementById('postLon').value;
            if (lat && lon && this.value) fetchWeather(parseFloat(lat), parseFloat(lon), this.value);
        });

        // Submit
        document.getElementById('createPostForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const btnSubmit = document.getElementById('btnSubmitPost');
            btnSubmit.disabled = true;
            btnSubmit.innerText = "CREATING...";

            const dateVal = document.getElementById('postDate').value;
            const timeVal = document.getElementById('postTime').value;

            // Validate: prevent past datetime
            const selectedDateTime = new Date(`${dateVal}T${timeVal}:00`);
            if (selectedDateTime <= new Date()) {
                alert('Please select a date and time in the future.');
                btnSubmit.disabled = false;
                btnSubmit.innerText = 'CREATE POST';
                return;
            }

            const latVal = document.getElementById('postLat').value;
            const lonVal = document.getElementById('postLon').value;

            const postData = {
                Title:         document.getElementById('postTitle').value,
                SportType:     document.getElementById('postSportType').value,
                MaxPeople:     parseInt(document.getElementById('postMaxPeople').value),
                Location:      document.getElementById('postLocation').value,
                EventDateTime: `${dateVal}T${timeVal}:00`,
                ImageUrl:      document.getElementById('postImageUrl').value || null,
                Description:   document.getElementById('postDescription').value,
                Lat:           latVal ? parseFloat(latVal) : null,
                Lon:           lonVal ? parseFloat(lonVal) : null
            };

            console.log("prepare sending to Backend:", postData);

            try {
                const res = await fetch('/api/postapi/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(postData)
                });

                if (res.ok) {
                    alert("Created Activity!");
                    window.location.href = "/Home/Index";
                } else {
                    const contentType = res.headers.get("content-type");
                    if (contentType && contentType.includes("application/json")) {
                        const error = await res.json();
                        alert("Error: " + (error.message || "Failed from server"));
                    } else {
                        alert(`Error ${res.status}: Connect to API maybe wrong`);
                    }
                    btnSubmit.disabled = false;
                    btnSubmit.innerText = "CREATE POST";
                }

            } catch (error) {
                console.error("Network Error:", error);
                alert("error from connecting server");
                btnSubmit.disabled = false;
                btnSubmit.innerText = "CREATE POST";
            }
        });
    </script>
}