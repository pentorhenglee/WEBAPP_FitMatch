@{
    ViewData["Title"] = "Post Detail";
}

@section Styles {
    <link rel="stylesheet" href="~/css/PostDetail.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}

<div class="post-detail-container">
    
    <div class="post-chat-section">
        <div class="chat-header">Chat</div>
        
        <div class="chat-messages" id="chatHistoryContainer">
            <div style="text-align:center; color:#888; font-size:0.8rem; margin-top:40px;">Loading chat...</div>
        </div>

        <div class="chat-input-area">
            <input type="text" id="chatInputMessage" placeholder="Type a message..." onkeypress="handleEnterKey(event)" />
            <button onclick="sendChatMessage()">
                <i class="fa-solid fa-chevron-right"></i>
            </button>
        </div>
    </div>

    <div class="post-info-section">
        <img src="https://via.placeholder.com/800x400?text=Cover+Image" id="displayCoverImg" class="post-cover-img" alt="Event Cover" style="display:none;" />
        
        <div class="post-details">
            <h2 id="displayTitle">Loading...</h2>
            
            <div class="post-meta" id="displayMeta">
                <span><i class="fa-solid fa-location-dot"></i> Loading...</span>
            </div>

            <div class="post-desc" id="displayDesc">Please wait, fetching data from database...</div>
        </div>

        <div class="post-info-footer">
            <div class="participants-count" id="displayParticipants">
                Participants: - / -
            </div>

            <div id="actionButtonsArea">
                <button class="btn-join" id="btnJoin" onclick="joinPost()" style="display: none;">JOIN</button>

                <div class="owner-actions-container" id="ownerActions">
                    <button class="btn-manage" onclick="openParticipantsModal()">MANAGE</button>
                    <button class="btn-edit" onclick="openEditModal()">EDIT</button>
                    <button class="btn-close" id="btnCloseToggle" onclick="toggleClosePost()">CLOSE</button>
                </div>
            </div>
        </div>
    </div>

    <div id="participantsModal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Participants</h3>
                <span class="close-modal" onclick="closeParticipantsModal()">&times;</span>
            </div>
            <div class="modal-body" id="participantsListContainer">
                <div style="text-align: center; color: #888;">Loading members...</div>
            </div>
        </div>
    </div>

    <div id="editPostModal" class="modal-overlay" style="display: none;">
        <div class="modal-content" style="max-width: 500px;">
            <div class="modal-header">
                <h3>Edit Post</h3>
                <span class="close-modal" onclick="closeEditModal()">&times;</span>
            </div>
            <div class="modal-body" style="text-align:left;">
                <div class="form-field">
                    <label>Title</label>
                    <input type="text" id="editTitle"/>
                </div>
                <div class="form-field">
                    <label>Location</label>
                    <input type="text" id="editLocation"/>
                </div>
                <div class="form-field">
                    <label>Event Date/Time</label>
                    <input type="datetime-local" id="editDateTime"/>
                </div>
                <div class="form-field">
                    <label>Sport Type</label>
                    <select id="editSportType">
                        <option value="Running">Running</option>
                        <option value="Cycling">Cycling</option>
                        <option value="Basketball">Basketball</option>
                        <option value="Soccer">Soccer</option>
                        <option value="Volleyball">Volleyball</option>
                    </select>
                </div>
                <div class="form-field">
                    <label>Max People</label>
                    <input type="number" id="editMaxPeople" min="2"/>
                </div>
                <div class="form-field">
                    <label>Image URL</label>
                    <input type="text" id="editImageUrl"/>
                </div>
                <div class="form-field">
                    <label>Description</label>
                    <textarea id="editDescription" rows="3"></textarea>
                </div>
                <button onclick="submitEditPost()" class="btn-save">Save Changes</button>
                <button onclick="deletePost()" class="btn-delete-post" style="margin-top:8px; width:100%; background:#c0392b; color:#fff; border:none; padding:10px; border-radius:6px; cursor:pointer; font-weight:bold;">Delete Post</button>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const currentPostId = @ViewBag.PostId; 
        let globalPostData = null; 

        function getSportPlaceholder(sportType) {
            const map = {
                'Running':    '/images/running_placeholder.jpg',
                'Soccer':     '/images/soccer_placeholder.jpg',
                'Basketball': '/images/basketball_placeholder.jpg',
                'Volleyball': '/images/volleyball_placeholder.jpg',
                'Cycling':    '/images/biking_placeholder.jpg',
            };
            return map[sportType] || '/images/placeholder-default.jpg';
        }

        function getSportIcon(sportType) {
            const icons = {
                'Running': 'fa-running',
                'Cycling': 'fa-bicycle',
                'Basketball': 'fa-basketball-ball',
                'Soccer': 'fa-futbol',
                'Volleyball': 'fa-volleyball-ball'
            };
            return icons[sportType] || 'fa-infinity';
        }

        // ==========================================
        // 1. ดึงข้อมูลโพสต์หลัก
        // ==========================================
        async function fetchPostDetail() {
            try {
                const response = await fetch(`/api/postapi/detail/${currentPostId}`);
                if (!response.ok) {
                    document.getElementById('displayTitle').innerText = "Post Not Found";
                    return;
                }
                
                globalPostData = await response.json(); 
                const data = globalPostData;

                const currentPeopleCount = data.members ? data.members.length : 0;

                const dateObj = new Date(data.eventDateTime);
                const dateStr = dateObj.toLocaleDateString('en-GB').replace(/\//g, ' - ');
                const timeStr = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });

                // จัดการรูปภาพ (ถ้าไม่มีให้โชว์ Placeholder เท่ๆ)
                const coverImg = document.getElementById('displayCoverImg');
                if (data.imageUrl && data.imageUrl.trim() !== "") {
                    coverImg.src = data.imageUrl;
                } else {
                    coverImg.src = getSportPlaceholder(data.sportType);
                }
                coverImg.style.display = "block";

                document.getElementById('displayTitle').innerText = data.title;
                
                // ตกแต่ง Meta data (สถานที่ วันเวลา และประเภทกีฬา)
                const sportIconClass = getSportIcon(data.sportType);
                document.getElementById('displayMeta').innerHTML = `
                    <span style="color: #2ecc71; font-weight: bold;"><i class="fas ${sportIconClass}"></i> ${(data.sportType || 'Unknown Sport').toUpperCase()}</span>
                    <span><i class="fa-solid fa-location-dot"></i> ${data.location}</span>
                    <span><i class="fa-regular fa-calendar"></i> ${dateStr}</span>
                    <span><i class="fa-regular fa-clock"></i> ${timeStr}</span>
                `;
                
                document.getElementById('displayDesc').innerText = data.description || "No description provided.";

                const participantsDiv = document.getElementById('displayParticipants');
                participantsDiv.innerHTML = `<span style="color:#aaa; font-size:0.9rem;">Participants:</span> <span style="font-weight:bold; cursor:pointer; margin-left:10px; color:var(--accent);" onclick="openParticipantsModal()"><i class="fa-solid fa-users" style="margin-right:5px;"></i> ${currentPeopleCount} / ${data.maxPeople}</span>`;

                // ==========================================
                // ลอจิกปุ่ม 
                // ==========================================
                const isOwner = data.ownerId === data.currentUserId;
                const isAlreadyJoined = data.members.some(m => m.userId === data.currentUserId);
                const isFull = currentPeopleCount >= data.maxPeople;
                const isClosed = data.status.toLowerCase() === "close" || data.status.toLowerCase() === "closed";

                const btnJoin = document.getElementById('btnJoin');

                if (isOwner) {
                    btnJoin.style.display = "none";
                    document.getElementById('ownerActions').style.display = "flex";
                    const btnCloseToggle = document.getElementById('btnCloseToggle');
                    if (isClosed) {
                        btnCloseToggle.innerText = "OPEN";
                        btnCloseToggle.style.backgroundColor = "#2ecc71"; // green for opening
                    } else {
                        btnCloseToggle.innerText = "CLOSE";
                        btnCloseToggle.style.backgroundColor = "#e74c3c"; // red for closing
                    }
                } else {
                    document.getElementById('ownerActions').style.display = "none";
                    btnJoin.style.display = "block";
                    
                    if (isClosed) {
                        btnJoin.innerText = "CLOSED";
                        btnJoin.disabled = true;
                        btnJoin.onclick = null;
                    } 
                    else if (isAlreadyJoined) {
                        btnJoin.innerText = "LEAVE EVENT";
                        btnJoin.disabled = false; 
                        btnJoin.onclick = leavePost; 
                    } 
                    else if (isFull) {
                        btnJoin.innerText = "FULL";
                        btnJoin.disabled = true;
                        btnJoin.onclick = null;
                    } 
                    else {
                        btnJoin.innerText = "JOIN";
                        btnJoin.disabled = false; 
                        btnJoin.onclick = joinPost; 
                    }
                }

                // ดึงแชทมาแสดงด้วย
                renderChats();

            } catch (error) { 
                console.error("Error fetching post detail:", error); 
                document.getElementById('displayTitle').innerText = "Error loading data.";
            }
        }

        // ==========================================
        // 2. ฟังก์ชัน API สำหรับปุ่มต่างๆ
        // ==========================================
        async function joinPost() {
            const btn = document.getElementById('btnJoin');
            btn.innerText = "JOINING...";
            btn.disabled = true;

            try {
                const response = await fetch(`/api/memberapi/join/${currentPostId}`, { method: 'POST' });
                if (response.ok) {
                    await fetchPostDetail(); 
                } else {
                    const errorText = await response.text();
                    alert("Failed to join: " + errorText);
                    btn.innerText = "JOIN";
                    btn.disabled = false;
                }
            } catch (error) {
                console.error("Error:", error);
                btn.innerText = "JOIN";
                btn.disabled = false;
            }
        }

        async function leavePost() {
            if(!confirm("Are you sure you want to leave this event?")) return;
            try {
                const response = await fetch(`/api/memberapi/leave/${currentPostId}`, { method: 'DELETE' });
                if (response.ok) {
                    await fetchPostDetail();
                } else {
                    const errorText = await response.text();
                    alert("Failed to leave: " + errorText);
                }
            } catch (error) { console.error("Error:", error); }
        }

        async function toggleClosePost() {
            const isClosed = globalPostData.status.toLowerCase() === "close" || globalPostData.status.toLowerCase() === "closed";
            const actionText = isClosed ? "open" : "close";
            if (!confirm(`Are you sure you want to ${actionText} this post?`)) return;
            
            try {
                const endpoint = isClosed ? `/api/postapi/open/${currentPostId}` : `/api/postapi/close/${currentPostId}`;
                const response = await fetch(endpoint, { method: 'PUT' });
                if (response.ok) {
                    await fetchPostDetail();
                } else {
                    const errorText = await response.text();
                    alert(`Failed to ${actionText} post: ` + errorText);
                }
            } catch (error) { console.error("Error:", error); }
        }

        function openEditModal() {
            if (!globalPostData) return;
            document.getElementById('editTitle').value = globalPostData.title;
            document.getElementById('editLocation').value = globalPostData.location;
            
            // Format datetime to local datetime format YYYY-MM-DDThh:mm
            // eventDateTime จาก DB ไม่มี timezone suffix → slice ตรงๆ ได้เลย
            document.getElementById('editDateTime').value = globalPostData.eventDateTime.slice(0, 16);
            
            document.getElementById('editSportType').value = globalPostData.sportType;
            const currentCount = globalPostData.members ? globalPostData.members.length : 0;
            const maxPeopleInput = document.getElementById('editMaxPeople');
            maxPeopleInput.min = currentCount;
            maxPeopleInput.value = globalPostData.maxPeople;
            document.getElementById('editImageUrl').value = globalPostData.imageUrl || "";
            document.getElementById('editDescription').value = globalPostData.description || "";
            
            document.getElementById('editPostModal').style.display = 'flex';
        }

        function closeEditModal() {
            document.getElementById('editPostModal').style.display = 'none';
        }

        async function submitEditPost() {
            const currentCount = globalPostData.members ? globalPostData.members.length : 0;
            const maxPeople = parseInt(document.getElementById('editMaxPeople').value);
            if (maxPeople < currentCount) {
                alert(`Cannot set max people below current participant count (${currentCount}).`);
                return;
            }
            const dto = {
                title: document.getElementById('editTitle').value,
                location: document.getElementById('editLocation').value,
                eventDateTime: document.getElementById('editDateTime').value + ':00',
                sportType: document.getElementById('editSportType').value,
                maxPeople: maxPeople,
                imageUrl: document.getElementById('editImageUrl').value,
                description: document.getElementById('editDescription').value
            };

            try {
                const response = await fetch(`/api/postapi/edit/${currentPostId}`, {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(dto)
                });
                
                if (response.ok) {
                    closeEditModal();
                    await fetchPostDetail();
                } else {
                    const err = await response.text();
                    alert("Edit failed: " + err);
                }
            } catch (error) { console.error("Error editing post:", error); }
        }

        async function deletePost() {
            if (!confirm("Are you sure you want to permanently delete this post? This cannot be undone.")) return;
            try {
                const response = await fetch(`/api/postapi/delete/${currentPostId}`, { method: 'DELETE' });
                if (response.ok) {
                    window.location.href = '/Dashboard';
                } else {
                    const err = await response.text();
                    alert("Delete failed: " + err);
                }
            } catch (error) { console.error("Error deleting post:", error); }
        }

        async function kickMember(userId) {
            if (!confirm("Are you sure you want to kick this member?")) return;
            try {
                const response = await fetch(`/api/memberapi/kick/${currentPostId}/${userId}`, { method: 'DELETE' });
                if (response.ok) {
                    await fetchPostDetail();
                    openParticipantsModal(); 
                } else {
                    const errorText = await response.text();
                    alert("Failed to kick: " + errorText);
                }
            } catch (error) { console.error("Error:", error); }
        }

        // ==========================================
        // 3. ระบบ Chat
        // ==========================================
        function renderChats() {
            const chatContainer = document.getElementById('chatHistoryContainer');
            if (!globalPostData || !globalPostData.comments || globalPostData.comments.length === 0) {
                chatContainer.innerHTML = '<div style="text-align:center; color:#888; margin-top:40px;">No messages yet.<br>Be the first to say hi!</div>';
                return;
            }

            chatContainer.innerHTML = '';
            
            globalPostData.comments.forEach(chat => {
                const isMine = chat.userId === globalPostData.currentUserId;
                const wrapperClass = isMine ? "mine" : "others";
                const avatarUrl = chat.profileUrl || 'https://via.placeholder.com/40';
                
                const dateObj = new Date(chat.comment_date);
                const now = new Date();
                const isToday = dateObj.toDateString() === now.toDateString();
                const timeOnly = dateObj.toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit', hour12: false });
                const timeStr = isToday
                    ? timeOnly
                    : dateObj.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) + ' ' + timeOnly;

                chatContainer.innerHTML += `
                    <div class="chat-message-wrapper ${wrapperClass}">
                        <img src="${avatarUrl}" class="chat-avatar" alt="${chat.username}" onclick="window.location.href='/Profile/UserProfile?id=${chat.userId}'" style="cursor:pointer;" title="View ${chat.username}'s profile">
                        <div class="chat-message-content">
                            <div class="chat-username">${chat.username} <span class="chat-time">${timeStr}</span></div>
                            <div class="chat-bubble">${chat.text}</div>
                        </div>
                    </div>
                `;
            });
            // เลื่อนลงไปล่างสุดเสมอเมื่อมีข้อความใหม่
            chatContainer.scrollTop = chatContainer.scrollHeight;
        }

        async function sendChatMessage() {
            const input = document.getElementById('chatInputMessage');
            const message = input.value.trim();
            if (!message) return;

            try {
                const response = await fetch(`/api/commentapi/${currentPostId}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ Text: message })
                });

                if (response.ok) {
                    input.value = ""; 
                    await fetchPostDetail(); // โหลดข้อมูลใหม่เพื่อดึงแชท
                } else {
                    alert("Failed to send message.");
                }
            } catch (error) {
                console.error("Error sending message:", error);
            }
        }

        function handleEnterKey(e) { if (e.key === 'Enter') sendChatMessage(); }

        // ==========================================
        // 4. Modal รายชื่อคน
        // ==========================================
        function openParticipantsModal() {
            document.getElementById('participantsModal').style.display = 'flex';
            renderParticipants(); 
        }

        function closeParticipantsModal() {
            document.getElementById('participantsModal').style.display = 'none';
        }

        function renderParticipants() {
            const container = document.getElementById('participantsListContainer');
            if (!globalPostData || !globalPostData.members || globalPostData.members.length === 0) {
                container.innerHTML = '<div style="text-align:center; color:#888;">No members yet.</div>';
                return;
            }
            container.innerHTML = '';
            
            const isCurrentUserOwner = globalPostData.ownerId === globalPostData.currentUserId;

            globalPostData.members.forEach(member => {
                const avatarSrc = member.profileUrl || 'https://via.placeholder.com/40'; 
                const isOwner = member.userId === globalPostData.ownerId;
                const ownerBadge = isOwner ? '<span class="owner-badge">Owner</span>' : '';
                
                let kickBtn = '';
                if (isCurrentUserOwner && !isOwner) {
                    kickBtn = `<button class="btn-kick" onclick="kickMember(${member.userId})">Kick</button>`;
                }

                container.innerHTML += `
                    <div class="participant-item">
                        <div style="display:flex; align-items:center; cursor:pointer;" onclick="window.location.href='/Profile/UserProfile?id=${member.userId}'" title="View ${member.name}'s profile">
                            <img src="${avatarSrc}" class="participant-avatar" alt="${member.name}">
                            <div style="margin-left:10px;">
                                <div class="participant-name">${member.name} ${ownerBadge}</div>
                            </div>
                        </div>
                        ${kickBtn}
                    </div>
                `;
            });
        }
        
        // ==========================================
        // Initialize
        // ==========================================
        document.addEventListener('DOMContentLoaded', () => {
            fetchPostDetail();
        });
    </script>
}