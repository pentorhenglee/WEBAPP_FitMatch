<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitMatch</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            @using Microsoft.AspNetCore.Http
            @{
                // ดึงค่าจาก Session มาเช็คตรงๆ
                var userName = Context.Session.GetString("user");
                var userEmail = Context.Session.GetString("user_email");
                var userAvatar = Context.Session.GetString("user_profile");
            }
            <a class="brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Logo" />
                <div>
                    <span class="text-fit">FIT</span><span class="text-match">MATCH</span>
                </div>
            </a>
            @if (!string.IsNullOrEmpty(userName))
            {
                <nav class="links">
                        <a href="/Profile">PROFILE</a>
                        <a href="/Dashboard">DASHBOARD</a>
                        <a href="/Profile/Missions">MISSIONS</a>
                        <a href="/Profile/About">ABOUT</a>
                        <a onclick="logout()" class="text-danger">LOGOUT</a>
                </nav>

                <div class="user-section" id="userSection" style="position: relative;">
                    <div class="user-text">
                        <div class="user-name" id="displayUserName">@userName</div>
                        <div class="user-email" id="displayUserEmail">@userEmail</div>
                    </div>

                    <button id="notificationBtn" class="notification-btn" title="Notifications">
                        <img src="@(string.IsNullOrEmpty(userAvatar) ? "/images/default-avatar.png" : userAvatar)"
                            id="displayUserAvatars" class="user-avatar" alt="Avatar" />
                        <span class="notif-badge" id="notifBadge" style="display:none;"></span>
                    </button>

                    <div id="notificationDropdown" class="notification-dropdown-menu">
                        <div class="notif-header">
                            <span>Notifications</span>
                            <span class="notif-count" id="notifCount">0</span>
                        </div>
                        <div id="notificationDisplay" class="notification-display"></div>
                    </div>
                </div>
            }
            else
            {
            <div id="authLinks"  class="auth-links">   
                <a asp-controller="Account" asp-action="Login" class="nav-link">Login</a>
                <a asp-controller="Account" asp-action="Register" class="nav-link btn-register">Register</a>
            </div>

            }

        </nav>
    </header>

    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script>
        // ── Profile fetch ──────────────────────────────────────────────────
        async function fetchUserProfile() {
            const userSection = document.getElementById('userSection');
            const authLinks   = document.getElementById('authLinks');
            try {
                const res = await fetch("/api/profileapi", { credentials: 'same-origin' });
                if (res.ok) {
                    const user = await res.json();
                    document.getElementById('displayUserName').innerText  = user.username;
                    document.getElementById('displayUserEmail').innerText = user.email;
                    if (user.profileUrl && user.profileUrl !== "") {
                        document.getElementById('displayUserAvatars').src = user.profileUrl;
                    } else {
                        document.getElementById('displayUserAvatars').src = "/images/profile_placeholder.png";
                    }
                    if (userSection) userSection.style.display = 'flex';
                    if (authLinks)   authLinks.style.display   = 'none';
                } else {
                    if (userSection) userSection.style.display = 'none';
                    if (authLinks)   authLinks.style.display   = 'flex';
                }
            } catch (err) { console.error(err); }
        }
        fetchUserProfile();

        // ── Logout ────────────────────────────────────────────────────────
        async function logout() {
            const res  = await fetch('/api/auth/logout', { method: 'POST', credentials: 'same-origin', headers: { 'Content-Type': 'application/json' } });
            const data = await res.json();
            if (data.success) window.location.href = '/Home/index';
        }

        // ── Active nav link ───────────────────────────────────────────────
        document.querySelectorAll('.links a').forEach(a => {
            if (a.href === window.location.href) a.classList.add('active');
        });

        // ── Notification dropdown toggle ──────────────────────────────────
        const _notifBtn  = document.getElementById('notificationBtn');
        const _notifMenu = document.getElementById('notificationDropdown');
        if (_notifBtn && _notifMenu) {
            _notifBtn.addEventListener('click', e => {
                e.stopPropagation();
                _notifMenu.classList.toggle('show');
            });
            document.addEventListener('click', e => {
                if (!_notifMenu.contains(e.target) && !_notifBtn.contains(e.target))
                    _notifMenu.classList.remove('show');
            });
        }

        // ── Notification types config ─────────────────────────────────────
        const NOTIF_TYPES = {
            Join:  { icon: 'fa-user-check',  color: '#2ecc71', label: 'Joined'  },
            Edit:  { icon: 'fa-pen-to-square', color: '#3498db', label: 'Updated' },
            Kick:  { icon: 'fa-user-xmark',  color: '#e74c3c', label: 'Removed' },
            Close:  { icon: 'fa-lock',        color: '#f39c12', label: 'Closed'  },
        };

        // ── Render notifications ───────────────────────────────────────────
        function renderNotifications(notifications) {
            const display = document.getElementById('notificationDisplay');
            const badge   = document.getElementById('notifBadge');
            const count   = document.getElementById('notifCount');
            display.innerHTML = '';

            if (!notifications || notifications.length === 0) {
                display.innerHTML = '<p class="no-notifications">You\'re all caught up!</p>';
                if (badge) badge.style.display = 'none';
                if (count) count.textContent = '0';
                return;
            }

            const unreadCount = notifications.filter(n => !n.isRead).length;
            if (badge) { 
                if (unreadCount > 0) {
                    badge.style.display = 'flex'; 
                    badge.textContent = unreadCount > 9 ? '9+' : unreadCount;
                } else {
                    badge.style.display = 'none';
                }
            }
            if (count) count.textContent = notifications.length;

            notifications.forEach(n => {
                const cfg  = NOTIF_TYPES[n.type] || { icon: 'fa-bell', color: '#aaa', label: n.type };
                const card = document.createElement('div');
                card.className = 'notification-card' + (n.isRead ? ' read' : ' unread');
                card.style.setProperty('--notif-color', cfg.color);
                card.innerHTML = `
                    <div class="notif-icon-wrap" style="background:${cfg.color}22; color:${cfg.color};">
                        <i class="fa-solid ${cfg.icon}"></i>
                    </div>
                    <div class="notif-body">
                        <div class="notif-type-badge" style="color:${cfg.color};">${cfg.label}</div>
                        <div class="notif-title">${n.message || 'No message'}</div>
                        <div class="notif-desc">${n.date || ''} · ${n.triggerName || 'Unknown'}</div>
                    </div>
                    ${!n.isRead ? '<div class="unread-indicator"></div>' : ''}
                `;
                card.addEventListener('click', async () => {
                    // Mark as read
                    if (!n.isRead) {
                        try {
                            await fetch('/api/NotificationAPI/read', {
                                method: 'POST',
                                credentials: 'same-origin',
                                headers: { 'Content-Type': 'application/json' },
                                body: JSON.stringify({ notificationId: n.notificationId })
                            });
                            n.isRead = true;
                            card.classList.remove('unread');
                            card.classList.add('read');
                            fetchNotifications(); // Refresh to update badge
                        } catch (err) {
                            console.error('Error marking notification as read:', err);
                        }
                    }
                    // Navigate to post
                    if (n.postId) window.location.href = `/Post/Detail?id=${n.postId}`;
                });
                display.appendChild(card);
            });
        }

        // ── Fetch notifications from API ──────────────────────────────────
        async function fetchNotifications() {
            try {
                const res = await fetch('/api/NotificationAPI/render', { 
                    credentials: 'same-origin' 
                });
                
                if (res.ok) {
                    const data = await res.json();
                    renderNotifications(data);
                } else {
                    console.warn('Failed to fetch notifications:', res.statusText);
                    renderNotifications([]);
                }
            } catch (err) {
                console.error('Error fetching notifications:', err);
                renderNotifications([]);
            }
        }
        fetchNotifications();
        // Refresh notifications every 30 seconds
        setInterval(fetchNotifications, 30000);
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
