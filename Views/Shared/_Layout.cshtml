<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitMatch</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            @using Microsoft.AspNetCore.Http
            @{
                // ดึงค่าจาก Session มาเช็คตรงๆ
                var userName = Context.Session.GetString("user");
                var userEmail = Context.Session.GetString("user_email");
            }
            <a class="brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Logo" />
                <div>
                    <span class="text-fit">FIT</span><span class="text-match">MATCH</span>
                </div>
            </a>
            @if (!string.IsNullOrEmpty(userName))
            {
                <nav class="links">
                        <a href="/Profile">PROFILE</a>
                        <a href="/Dashboard">DASHBOARD</a>
                        <a href="/Profile/Missions">MISSIONS</a>
                        <a href="/Profile/About">ABOUT</a>
                        <a onclick="logout()" class="text-danger">LOGOUT</a>
                </nav>

                <div class="user-section" id="userSection" style=" position: relative;">   
                    <div class="user-text">
                        <div class="user-name" id="displayUserName">@userName</div>
                        <div class="user-email" id="displayUserEmail">@userEmail</div>
                    </div>
                    
                    <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                        id="displayUserAvatar" class="user-avatar" alt="Avatar"/>

                </div>
            }
            else
            {
            <div id="authLinks"  class="auth-links">   
                <a asp-controller="Account" asp-action="Login" class="nav-link">Login</a>
                <a asp-controller="Account" asp-action="Register" class="nav-link btn-register">Register</a>
            </div>

            }

        </nav>
    </header>

    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script>
        async function fetchUserProfile() {
            const userSection = document.getElementById('userSection');
            const authLinks = document.getElementById('authLinks');

            try {
                const res = await fetch("/api/profileapi", { credentials: 'same-origin' });

                if (res.ok) {
                    const user = await res.json();
                    
                    document.getElementById('displayUserName').innerText = user.username;
                    document.getElementById('displayUserEmail').innerText = user.email;
                    
                    if (user.profileUrl && user.profileUrl !== "") {
                        document.getElementById('displayUserAvatar').src = user.profileUrl;
                    }

                    userSection.style.display = 'flex';
                    authLinks.style.display = 'none';
                } else {
                    userSection.style.display = 'none';
                    authLinks.style.display = 'flex';
                }

            } catch (error) {
                console.error("เกิดข้อผิดพลาดในการดึงข้อมูล:", error);
            }
        }
        fetchUserProfile();

        async function logout(){
            const res = await fetch('/api/auth/logout', {
                method: "POST",
                credentials: 'same-origin',
                headers: {'Content-Type': 'application/json'}
            });
            
            const data = await res.json();
            if (data.success){
                window.location.href = "/Home/index";
            }
        }

        document.querySelectorAll('.links a').forEach(a => {
            if (a.href === window.location.href) a.classList.add('active');
        });
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
