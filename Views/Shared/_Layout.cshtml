<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitMatch</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            <a class="brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Logo" />
                <div>
                    <span class="text-fit">FIT</span><span class="text-match">MATCH</span>
                </div>
            </a>

            <div class="user-section">
                <div class="user-text">
                    <div class="user-name" id="displayUserName">Loading...</div>
                    <div class="user-email" id="displayUserEmail">Loading...</div>
                </div>
                <a asp-controller="Profile" asp-action="Index" aria-label="View Profile">
                    <img src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7" 
                         id="displayUserAvatar" 
                         class="user-avatar" 
                         alt="Avatar" />
                </a>
            </div>
        </nav>
    </header>

    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script>
        async function fetchUserProfile() {
            try {
                // TODO: เมื่อ Backend เสร็จ ให้เปลี่ยนตรงนี้เป็น fetch('/api/User/1')
                // ตอนนี้เราจำลองว่าดึงข้อมูลสำเร็จแล้ว
                const mockDataFromAPI = {
                    name: "EARTHY",
                    email: "SUPHASIN@KMITL.AC.TH",
                    avatarUrl: "" // ถ้า Backend ไม่มีรูปส่งมา มันจะเป็นรูปสีขาวๆ ที่เราตั้งไว้
                };

                // เอาข้อมูลที่ Fetch ได้ไปยัดใส่ HTML
                document.getElementById('displayUserName').innerText = mockDataFromAPI.name;
                document.getElementById('displayUserEmail').innerText = mockDataFromAPI.email;

                // ถ้ายูสเซอร์มีรูป ค่อยเอารูปมาทับสีขาว
                if (mockDataFromAPI.avatarUrl !== "") {
                    document.getElementById('displayUserAvatar').src = mockDataFromAPI.avatarUrl;
                }

            } catch (error) {
                console.error("เกิดข้อผิดพลาดในการดึงข้อมูล:", error);
            }
        }

        // สั่งให้ดึงข้อมูลทันทีที่เปิดเว็บ
        fetchUserProfile();
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>