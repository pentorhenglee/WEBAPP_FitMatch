<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FitMatch</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar">
            @using Microsoft.AspNetCore.Http
            @{
                var userName = Context.Session.GetString("user");
                var userEmail = Context.Session.GetString("user_email");
                var userAvatar = Context.Session.GetString("user_profile");
            }
            <a class="brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo.png" alt="Logo" />
                <div>
                    <span class="text-fit">FIT</span><span class="text-match">MATCH</span>
                </div>
            </a>
            @if (!string.IsNullOrEmpty(userName))
            {
                <nav class="links">
                        <a href="/Profile">PROFILE</a>
                        <a href="/Dashboard">DASHBOARD</a>
                        <a href="/Profile/Missions">MISSIONS</a>
                        <a href="/Profile/About">ABOUT</a>
                        <a onclick="logout()" class="text-danger">LOGOUT</a>
                </nav>

                <div class="user-section" id="userSection" style=" position: relative;">   
                    <div class="user-text">
                        <div class="user-name" id="displayUserName">@userName</div>
                        <div class="user-email" id="displayUserEmail">@userEmail</div>
                    </div>
                    
                    <button id="notificationBtn" class="notification-btn">
                        <img src="@(string.IsNullOrEmpty(userAvatar) ? "/images/default-avatar.png" : userAvatar)" 
                            id="displayUserAvatars" class="user-avatar" alt="Avatar"/>
                    </button>
                    
                    <div id="notificationDropdown" class="notification-dropdown-menu">
                        <div id="notificationDisplay" class="notification-display"></div>
                    </div>

                </div>
            }
            else
            {
                <div id="authLinks"  class="auth-links">   
                    <a asp-controller="Account" asp-action="Login" class="nav-link">Login</a>
                    <a asp-controller="Account" asp-action="Register" class="nav-link btn-register">Register</a>
                </div>
            }
        </nav>
    </header>

    <div class="page-wrapper">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <script>
        async function fetchUserProfile() {
            const userSection = document.getElementById('userSection');
            const authLinks = document.getElementById('authLinks');

            try {
                const res = await fetch("/api/profileapi", { credentials: 'same-origin' });

                if (res.ok) {
                    const user = await res.json();
                    
                    document.getElementById('displayUserName').innerText = user.username;
                    document.getElementById('displayUserEmail').innerText = user.email;
                    
                    if (user.profileUrl && user.profileUrl !== "") {
                        document.getElementById('displayUserAvatars').src = user.profileUrl;
                    }

                    userSection.style.display = 'flex';
                    authLinks.style.display = 'none';
                } else {
                    userSection.style.display = 'none';
                    authLinks.style.display = 'flex';
                }

            } catch (error) {
                console.error("เกิดข้อผิดพลาดในการดึงข้อมูล:", error);
            }
        }
        fetchUserProfile();

        async function logout(){
            const res = await fetch('/api/auth/logout', {
                method: "POST",
                credentials: 'same-origin',
                headers: {'Content-Type': 'application/json'}
            });
            
            const data = await res.json();
            if (data.success){
                window.location.href = "/Home/index";
            }
        }

// Toggle dropdown when clicking the avatar or button
document.getElementById('notificationBtn').addEventListener('click', function(event) {
    event.stopPropagation(); // Prevents the event from bubbling up to the document
    const dropdown = document.getElementById('notificationDropdown');
    dropdown.classList.toggle('show');
});

// Close dropdown when clicking anywhere else on the page
document.addEventListener('click', function(event) {
    const dropdown = document.getElementById('notificationDropdown');
    const notificationBtn = document.getElementById('notificationBtn');

    // If the click is NOT on the dropdown or the button, hide it
    if (!dropdown.contains(event.target) && !notificationBtn.contains(event.target)) {
        dropdown.classList.remove('show');
    }
});
        async function renderNotifications(notifications) {
            const notificationDisplay = document.getElementById('notificationDisplay');
            notificationDisplay.innerHTML = '';

            if (!notifications || (Array.isArray(notifications) && notifications.length === 0)) {
                notificationDisplay.innerHTML = '<p class="no-notifications">No notifications found.</p>';
                return;
            }

            const notificationArray = Array.isArray(notifications) ? notifications : [notifications];

            notificationArray.forEach(notification => {
                const card = document.createElement('div');
                card.className = 'notification-card';

                card.innerHTML = `
                    <button class="view-more-btn" data-post-id="${notification.postId}">
                        <div class="notification-card">
                            <h3 class="notification-title">${notification.title || 'Untitled'}</h3>
                            <p class="notification-description">${notification.description || ''}</p>
                        </div>
                    </button>
                    `;

                const viewMoreBtn = card.querySelector(".view-more-btn");
                viewMoreBtn.addEventListener("click", function (e) {
                    e.stopPropagation();
                    const id = this.getAttribute("data-post-id"); 
                    if (id) {
                        window.location.href = `/Post/Detail?id=${id}`;
                    }
                });

                notificationDisplay.appendChild(card);
            });
        }

        async function fetchNotifications() {
            try {
                const mockNotifications = [
                    {
                        postId: 1,
                        title: "New Workout Challenge",
                        description: "Join our 30-day fitness challenge"
                    },
                    {
                        postId: 2,
                        title: "Gym Opening Announcement",
                        description: "New gym location is now open"
                    },
                    {
                        postId: 3,
                        title: "Fitness Tips Update",
                        description: "Check out our latest fitness tips and tricks"
                    }
                ];
                renderNotifications(mockNotifications);
            } catch (error) {
                console.error("Error fetching notifications:", error);
            }
        }

        fetchNotifications();
    </script>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
