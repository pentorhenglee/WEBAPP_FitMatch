@{
    ViewData["Title"] = "My Missions";
}

@section Styles {
    <link rel="stylesheet" href="~/css/Profile.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
}

<div class="missions-page-container">

    <div class="missions-header">
        <div>
            <h2 class="missions-title"><i class="fa-solid fa-bullseye"></i> My Missions</h2>
            <p class="missions-subtitle">Set your personal goals — tick them off as you go.</p>
        </div>
        <div class="missions-summary" id="missionSummary">
            <span id="summaryDone">0</span> / <span id="summaryTotal">0</span> done
        </div>
    </div>

    <!-- Add Mission Input -->
    <div class="mission-add-bar">
        <input type="text" id="missionInput" class="mission-input" 
               placeholder="Write your goal, e.g. Run 5km three times a week..." 
               maxlength="200"
               onkeydown="if(event.key==='Enter') addMission()" />
        <button class="mission-add-btn" onclick="addMission()">
            <i class="fa-solid fa-plus"></i> Add
        </button>
    </div>

    <!-- Filter Tabs -->
    <div class="mission-filter-tabs">
        <button class="mf-tab active" onclick="filterMissions('all', this)">All</button>
        <button class="mf-tab" onclick="filterMissions('todo', this)">Todo</button>
        <button class="mf-tab" onclick="filterMissions('done', this)">Done</button>
    </div>

    <!-- Mission List -->
    <div id="missionListMain" class="mission-list-main">
        <div class="mission-loading"><i class="fa-solid fa-spinner fa-spin"></i> Loading...</div>
    </div>

</div>

@section Scripts {
<script>
    let allMissions = [];
    let currentFilter = 'all';

    // ─── Fetch all missions ─────────────────────────────────────────
    async function loadMissions() {
        try {
            const res = await fetch('/api/MissionAPI/mission');
            if (!res.ok) throw new Error();
            allMissions = await res.json();
            renderMissions();
        } catch {
            document.getElementById('missionListMain').innerHTML =
                '<p style="color:#888; text-align:center; padding:40px;">Failed to load missions.</p>';
        }
    }

    // ─── Render filtered list ────────────────────────────────────────
    function renderMissions() {
        const container = document.getElementById('missionListMain');
        let filtered = allMissions;
        if (currentFilter === 'todo')  filtered = allMissions.filter(m => !m.isCompleted);
        if (currentFilter === 'done')  filtered = allMissions.filter(m => m.isCompleted);

        // summary
        const done  = allMissions.filter(m => m.isCompleted).length;
        const total = allMissions.length;
        document.getElementById('summaryDone').textContent  = done;
        document.getElementById('summaryTotal').textContent = total;

        if (filtered.length === 0) {
            container.innerHTML = `
                <div class="missions-empty">
                    <i class="fa-regular fa-note-sticky" style="font-size:2.5rem; margin-bottom:12px; color:#555;"></i>
                    <p>${currentFilter === 'all' ? 'No missions yet. Add one above!' :
                        currentFilter === 'todo' ? 'Nothing left to do!' : 'No completed missions yet.'}</p>
                </div>`;
            return;
        }

        container.innerHTML = filtered.map(m => `
            <div class="mission-note ${m.isCompleted ? 'mission-done' : ''}" id="note-${m.missionId}" data-id="${m.missionId}">
                <label class="mission-check-wrap">
                    <input type="checkbox" class="mission-checkbox" ${m.isCompleted ? 'checked' : ''}
                           onchange="tickMission(${m.missionId}, this)">
                    <span class="mission-checkmark"></span>
                </label>
                <span class="mission-desc">${escapeHtml(m.description)}</span>
                <div class="mission-meta">
                    <span class="mission-date">${formatDate(m.createdAt)}</span>
                    <button class="mission-del-btn" onclick="deleteMission(${m.missionId})" title="Delete">
                        <i class="fa-solid fa-trash-can"></i>
                    </button>
                </div>
            </div>
        `).join('');
    }

    // ─── Add mission ─────────────────────────────────────────────────
    async function addMission() {
        const input = document.getElementById('missionInput');
        const description = input.value.trim();
        if (!description) { input.focus(); return; }

        const btn = document.querySelector('.mission-add-btn');
        btn.disabled = true;

        try {
            const res = await fetch('/api/MissionAPI/addmission', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ description })
            });
            if (!res.ok) throw new Error();
            input.value = '';
            await loadMissions();
        } catch {
            alert('Failed to add mission.');
        } finally {
            btn.disabled = false;
        }
    }

    // ─── Tick / untick ───────────────────────────────────────────────
    async function tickMission(id, checkbox) {
        const note = document.getElementById(`note-${id}`);
        note.style.opacity = '0.5';

        try {
            const res = await fetch('/api/MissionAPI/tick', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ missionId: id })
            });
            if (!res.ok) throw new Error();
            await loadMissions();
        } catch {
            alert('Failed to update. Please try again.');
            checkbox.checked = !checkbox.checked;
            note.style.opacity = '1';
        }
    }

    // ─── Delete mission ──────────────────────────────────────────────
    async function deleteMission(id) {
        if (!confirm('Delete this mission?')) return;
        const note = document.getElementById(`note-${id}`);
        note.style.opacity = '0.4';

        try {
            const res = await fetch(`/api/MissionAPI/${id}`, { method: 'DELETE' });
            if (!res.ok) throw new Error();
            allMissions = allMissions.filter(m => m.missionId !== id);
            renderMissions();
        } catch {
            alert('Failed to delete mission.');
            note.style.opacity = '1';
        }
    }

    // ─── Filter tabs ─────────────────────────────────────────────────
    function filterMissions(filter, btn) {
        currentFilter = filter;
        document.querySelectorAll('.mf-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderMissions();
    }

    // ─── Helpers ─────────────────────────────────────────────────────
    function escapeHtml(str) {
        return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }
    function formatDate(iso) {
        if (!iso) return '';
        const d = new Date(iso);
        return d.toLocaleDateString('en-GB', { day:'numeric', month:'short', year:'numeric', timeZone: 'Asia/Bangkok' });
    }

    document.addEventListener('DOMContentLoaded', loadMissions);
</script>
}
