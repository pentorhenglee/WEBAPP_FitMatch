@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/Profile.css" asp-append-version="true"/>
}

<div class="profile-page-container">
    <div class="profile-card">
        <div class="profile-sidebar">
            <div class="avatar-wrapper">
                <img id="displayUserAvatar" 
                     class="profile-image-large" 
                     alt="User Avatar"/>
            </div>
            <button class="edit-profile-btn" id="edit-profile-btn">
                <i class="fas fa-edit"></i> Edit Profile
            </button>
        </div>

        <div class="profile-main-info">
            <div class="info-group">
                <span class="label">Display Name</span>
                <h1></h1>
            </div>

            <div class="info-group">
                <span class="label">Email Address</span>
                <p class="user-email-text"></p>
            </div>

            <div class="info-group">
                <span class="label">Bio</span>
                <p class="user-bio-text">
                    "Fitness enthusiast. No bio written yet."
                </p>
            </div>

            @* <div class="profile-stats">
                <div class="stat-item">
                    <span class="stat-value">FitMatch</span>
                    <span class="stat-label">Member</span>
                </div>
            </div> *@
        </div>
    </div>

    <div id="editProfileModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Update Profile</h2>
                <button id="closeModal" class="close-btn">&times;</button>
            </div>
            
            <form id="editProfileForm">
                <div class="form-group" style="text-align: center;">
                    <label>New Avatar Preview</label>
                    <div class="avatar-wrapper" style="margin: 10px auto; width: 100px; height: 100px; border: 2px solid var(--accent);">
                        <img id="urlPreview"
                             src="https://via.placeholder.com/100?text=No+Image"
                             style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Profile Image URL</label>
                    <input type="text" id="editAvatarUrl" placeholder="Paste image link..." value=""/>
                </div>

                <div class="form-group">
                    <label>Username</label>
                    <input type="text" id="editUsername" value="" required/>
                </div>

                <div class="form-group">
                    <label>Bio</label>
                    <textarea id="editBio" rows="4"></textarea>
                </div>

                <div class="modal-actions">
                    <button type="button" id="cancelBtn" class="secondary-btn">Cancel</button>
                    <button type="submit" class="save-btn" id="saveBtn">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    async function fetchUserProfile() {
            try {
                const res = await fetch("/api/profileapi", { credentials: 'same-origin' });

                if (res.ok) {
                    const user = await res.json();
                    console.log('Fetched user object:', user); // debug output

                    document.querySelector('.info-group h1').innerText = user.username || "Unknown User";
                    
                    const emailElem = document.querySelector('.user-email-text');
                    if(emailElem) emailElem.innerText = user.email;

                    const bioElem = document.querySelector('.user-bio-text');
                    // backend uses property 'info' so fall back accordingly
                    const bioValue = user.info || "";
                    if(bioElem) bioElem.innerText = bioValue || "Fitness enthusiast. No bio written yet.";
                    
                    const mainAvatar = document.getElementById('displayUserAvatar');
                    // always set src, use placeholder if emptiness
                    if (mainAvatar) {
                        // เช็คทั้ง profileUrl และ ProfileUrl
                        mainAvatar.src = user.profileUrl || "/images/default-avatar.png";
                    }

                } else {
                    console.error("ไม่สามารถดึงข้อมูลโปรไฟล์ได้");
                }

            } catch (error) {
                console.error("เกิดข้อผิดพลาดในการดึงข้อมูล:", error);
            }
        }
        document.addEventListener('DOMContentLoaded', fetchUserProfile);


    const modal = document.getElementById('editProfileModal');
    const editBtn = document.getElementById('edit-profile-btn');
    const closeBtn = document.getElementById('closeModal');
    const cancelBtn = document.getElementById('cancelBtn');
    const editForm = document.getElementById('editProfileForm');
    
    // Preview Elements
    const urlInput = document.getElementById('editAvatarUrl');
    const previewImg = document.getElementById('urlPreview');

    // Live URL Preview Logic
    urlInput.addEventListener('input', () => {
        const url = urlInput.value.trim();
        // Update preview image source immediately
        previewImg.src = url || "https://via.placeholder.com/100?text=No+Image";
    });

    // Handle broken image URLs
    previewImg.onerror = () => {
        if (!previewImg.src.includes('/images/default-avatar.png')) {
            previewImg.src = "/images/default-avatar.png"; 
        }
    };

    // Modal Control
    const openModal = async () => { 
        const currentName = document.querySelector('.info-group h1').innerText;
        const currentBio = document.querySelector('.user-bio-text').innerText;
        const currentAvatar = document.getElementById('displayUserAvatar').src;

        document.getElementById('editUsername').value = currentName;
        // ล้างข้อความ default ออกถ้ายังไม่ได้เขียน bio
        document.getElementById('editBio').value = currentBio.includes("No bio written yet") ? "" : currentBio;
        
        // สำคัญ: ส่งค่าไปที่ Input และตัว Preview
        document.getElementById('editAvatarUrl').value = currentAvatar;
        previewImg.src = currentAvatar; // อัปเดตตัว preview ใน modal ให้ตรงกับหน้าหลัก

        modal.style.display = 'flex';
    };
    const closeModal = () => { modal.style.display = 'none'; };

    editBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);

    window.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
    });

    // Form Submission
    editForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = document.getElementById('saveBtn');
        const avatarInput = document.getElementById('editAvatarUrl').value.trim();
        const nameInput = document.getElementById('editUsername').value.trim();
        const bioInput = document.getElementById('editBio').value.trim();

        submitBtn.disabled = true;
        submitBtn.innerText = "Saving...";

        const updatedData = {
            username: nameInput,
            info: bioInput,
            profileUrl: avatarInput
        };

        try {
            const response = await fetch('/api/profileapi/update', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(updatedData)
            });

            if (response.ok) {
                // --- ส่วนที่เพิ่มเข้ามา: อัปเดต UI ทันทีโดยไม่ต้อง Reload ---
                // 1. อัปเดตชื่อในหน้า Profile
                document.querySelector('.info-group h1').innerText = nameInput;
                
                // 2. อัปเดต Bio (ถ้าว่างให้โชว์ Default)
                document.querySelector('.user-bio-text').innerText = bioInput || "Fitness enthusiast. No bio written yet.";
                
                // 3. อัปเดตรูป Profile หลัก
                const mainAvatar = document.getElementById('displayUserAvatar');
                if (avatarInput) {
                    mainAvatar.src = avatarInput;
                }

                // 4. ปิด Modal
                closeModal();
                
                // (Optional) แสดงแจ้งเตือนเล็กๆ ว่าบันทึกสำเร็จ
                console.log("Profile updated successfully!");
                
            } else {
                const errorText = await response.text();
                alert("Update failed: " + errorText);
            }
        } catch (error) {
            console.error("Error:", error);
            alert("A network error occurred.");
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerText = "Save Changes";
        }
    });
</script>