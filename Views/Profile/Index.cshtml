@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/css/Profile.css" asp-append-version="true"/>
}

<div class="profile-page-container">
    <div class="profile-card">
        <div class="profile-sidebar">
            <div class="avatar-wrapper">
                <img id="displayUserAvatar" 
                     src="/images/default-avatar.png"
                     data-raw-src=""
                     class="profile-image-large" 
                     alt="Profile Picture"/>
            </div>
            <button class="edit-profile-btn" id="edit-profile-btn">
                <i class="fas fa-edit"></i> Edit Profile
            </button>
        </div>

        <div class="profile-main-info">
            <div class="info-group">
                <span class="label">Display Name</span>
                <h1 id="displayName">Loading...</h1>
            </div>

            <div class="info-group">
                <span class="label">Email Address</span>
                <p id="displayEmail" class="user-email-text"></p>
            </div>

            <div class="info-group">
                <span class="label">Bio</span>
                <p id="displayBio" class="user-bio-text">
                    No bio written yet.
                </p>
            </div>
        </div>
    </div>

    <div id="editProfileModal" class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h2>Update Profile</h2>
                <button id="closeModal" class="close-btn">&times;</button>
            </div>
            
            <form id="editProfileForm">
                <div class="form-group" style="text-align: center;">
                    <label>New Avatar Preview</label>
                    <div class="avatar-wrapper" style="margin: 10px auto; width: 100px; height: 100px; border: 2px solid var(--accent);">
                        <img id="urlPreview"
                             src="https://via.placeholder.com/100?text=No+Image"
                             style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;" />
                    </div>
                </div>

                <div class="form-group">
                    <label>Profile Image URL</label>
                    <input type="text" id="editAvatarUrl" placeholder="Paste image link (https://...)" value=""/>
                </div>

                <div class="form-group">
                    <label>Username</label>
                    <input type="text" id="editUsername" required/>
                </div>

                <div class="form-group">
                    <label>Bio</label>
                    <textarea id="editBio" rows="4" placeholder="Tell us about yourself..."></textarea>
                </div>

                <div class="modal-actions">
                    <button type="button" class="secondary-btn" id="cancelBtn">Cancel</button>
                    <button type="submit" class="save-btn" id="saveBtn">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    // --- Data Fetching ---
    async function fetchUserProfile() {
        try {
            const res = await fetch("/api/profileapi", { credentials: 'same-origin' });
            if (res.ok) {
                const user = await res.json();
                
                // Update UI text
                document.getElementById('displayName').innerText = user.username || "Unknown User";
                document.getElementById('displayEmail').innerText = user.email || "";
                document.getElementById('displayBio').innerText = user.info || "Fitness enthusiast. No bio written yet.";
                
                // Update Image and save the raw URL string
                const mainAvatar = document.getElementById('displayUserAvatar');
                const rawUrl = user.profileUrl || "";
                mainAvatar.src = rawUrl || "/images/default-avatar.png";
                mainAvatar.setAttribute('data-raw-src', rawUrl);
            }
        } catch (error) {
            console.error("Error fetching profile:", error);
        }
    }

    document.addEventListener('DOMContentLoaded', fetchUserProfile);

    // --- Modal Logic ---
    const modal = document.getElementById('editProfileModal');
    const editBtn = document.getElementById('edit-profile-btn');
    const closeBtn = document.getElementById('closeModal');
    const cancelBtn = document.getElementById('cancelBtn');
    const editForm = document.getElementById('editProfileForm');
    
    const urlInput = document.getElementById('editAvatarUrl');
    const previewImg = document.getElementById('urlPreview');

    // Live Preview
    urlInput.addEventListener('input', () => {
        const url = urlInput.value.trim();
        previewImg.src = url || "https://via.placeholder.com/100?text=No+Image";
    });

    previewImg.onerror = () => {
        previewImg.src = "https://via.placeholder.com/100?text=Invalid+URL";
    };

    const openModal = () => {
        const currentName = document.getElementById('displayName').innerText;
        const currentBio = document.getElementById('displayBio').innerText;
        const currentRawAvatar = document.getElementById('displayUserAvatar').getAttribute('data-raw-src');

        document.getElementById('editUsername').value = currentName === "Loading..." ? "" : currentName;
        document.getElementById('editBio').value = currentBio.includes("No bio written yet") ? "" : currentBio;
        
        // Use the raw URL so we don't paste "http://localhost.../default-avatar.png" into the input
        urlInput.value = currentRawAvatar;
        previewImg.src = currentRawAvatar || "https://via.placeholder.com/100?text=No+Image";

        modal.style.display = 'flex';
    };

    const closeModal = () => { modal.style.display = 'none'; };

    editBtn.addEventListener('click', openModal);
    closeBtn.addEventListener('click', closeModal);
    cancelBtn.addEventListener('click', closeModal);
    window.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

    // --- Form Submission ---
    editForm.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = document.getElementById('saveBtn');
        const avatarValue = urlInput.value.trim();
        const nameValue = document.getElementById('editUsername').value.trim();
        const bioValue = document.getElementById('editBio').value.trim();

        submitBtn.disabled = true;
        submitBtn.innerText = "Saving...";

        const updatedData = {
            username: nameValue,
            info: bioValue,
            profileUrl: avatarValue
        };

        try {
            const response = await fetch('/api/profileapi/update', {
                method: 'POST',
                credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(updatedData)
            });

            if (response.ok) {
                // Update Main Page UI immediately
                document.getElementById('displayName').innerText = nameValue;
                document.getElementById('displayBio').innerText = bioValue || "Fitness enthusiast. No bio written yet.";
                
                const mainAvatar = document.getElementById('displayUserAvatar');
                mainAvatar.src = avatarValue || "/images/default-avatar.png";
                mainAvatar.setAttribute('data-raw-src', avatarValue);

                closeModal();
            } else {
                const errorText = await response.text();
                alert("Update failed: " + errorText);
            }
        } catch (error) {
            console.error("Error:", error);
            alert("A network error occurred.");
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerText = "Save Changes";
        }
    });
</script>